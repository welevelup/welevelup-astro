---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { extract } from '../lib/extractHtml';
import homeRaw from '../_clone/index.html?raw';
const { headInner, bodyClass } = extract(homeRaw);
---

<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://welevelup.org" },
      { "@type": "ListItem", "position": 2, "name": "Who We Are", "item": "https://welevelup.org/who-we-are" }
    ]
  })}</script>

  <title>Who We Are — Level Up</title>

  <section class="wwa-hero" aria-labelledby="wwa-hero-heading">
    <div class="wwa-hero-inner">
      <span class="wwa-eyebrow">The Team</span>
      <h1 id="wwa-hero-heading" class="wwa-hero-title">Meet Our Team</h1>
    </div>
  </section>

  <section class="wwa-team" aria-labelledby="wwa-team-heading">
    <div class="wwa-team-inner">
      <div class="wwa-team-grid">

        <article class="wwa-card">
          <div class="wwa-card-photo">
            <img src="/team/Ruvimbo-Kuuzabuwe.webp" alt="Ruvimbo Kuuzabuwe" loading="lazy" />
          </div>
          <h2 class="wwa-card-name">Ruvimbo Kuuzabuwe</h2>
          <p class="wwa-card-role">Creative Content Strategist</p>
          <p class="wwa-card-fun">When I'm not fighting gender injustice I'm making music</p>
        </article>

        <article class="wwa-card">
          <div class="wwa-card-photo">
            <img src="/team/Seyi-Falodun-Liburd.webp" alt="Seyi Falodun-Liburd" loading="lazy" />
          </div>
          <h2 class="wwa-card-name">Seyi Falodun-Liburd</h2>
          <p class="wwa-card-role">Strategy and Fundraising</p>
          <p class="wwa-card-fun">When I'm not interrupting gender injustice I'm usually listening to music or a podcast while painting</p>
        </article>

        <article class="wwa-card">
          <div class="wwa-card-photo">
            <img src="/team/Jade-Hammond.webp" alt="Jade Hammond" loading="lazy" />
          </div>
          <h2 class="wwa-card-name">Jade Hammond</h2>
          <p class="wwa-card-role">Digital Comms Strategist</p>
          <p class="wwa-card-fun">When I'm not interrupting gender injustice, I'm dancing, drawing or going down internet rabbit holes on psychology and/or sharks</p>
        </article>

        <article class="wwa-card">
          <div class="wwa-card-photo">
            <img src="/team/Janey-Starling.webp" alt="Janey Starling" loading="lazy" />
          </div>
          <h2 class="wwa-card-name">Janey Starling</h2>
          <p class="wwa-card-role">Strategy and Campaigning</p>
          <p class="wwa-card-fun">When I'm not interrupting gender injustice at Level Up, you can find me singing in a punk band, tending to the flowers in my garden or lifting weights.</p>
        </article>

        <article class="wwa-card">
          <div class="wwa-card-photo">
            <img src="/team/Ikamara-Larasi.webp" alt="Ikamara Larasi" loading="lazy" />
          </div>
          <h2 class="wwa-card-name">Ikamara Larasi</h2>
          <p class="wwa-card-role">Campaigner</p>
          <p class="wwa-card-fun">When I'm not interrupting gender injustice I'm usually nerding out on genealogy and music.</p>
        </article>

        <article class="wwa-card">
          <div class="wwa-card-photo">
            <img src="/team/Catalina-Rojas-Ugarte.webp" alt="Catalina Rojas Ugarte" loading="lazy" />
          </div>
          <h2 class="wwa-card-name">Catalina Rojas Ugarte</h2>
          <p class="wwa-card-role">Tech Lead</p>
          <p class="wwa-card-fun">When I'm not interrupting gender injustice, I'm cooking or planning a trip to Greece.</p>
          <a href="https://www.linkedin.com/in/catalina-rojas-ugarte/" class="wwa-linkedin" target="_blank" rel="noopener" aria-label="Catalina Rojas Ugarte on LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </article>

        <article class="wwa-card">
          <div class="wwa-card-photo">
            <img src="/team/Sabrina-Anne-Sarpong.webp" alt="Sabrina-Anne Sarpong" loading="lazy" />
          </div>
          <h2 class="wwa-card-name">Sabrina-Anne Sarpong</h2>
          <p class="wwa-card-role">Finance</p>
        </article>

      </div>
    </div>
  </section>

  <section class="wwa-advisory" aria-labelledby="wwa-advisory-heading">
    <div class="wwa-advisory-inner">
      <div class="wwa-advisory-col">
        <h2 id="wwa-advisory-heading" class="wwa-advisory-title">Strategic Advisory Group</h2>
        <ul class="wwa-advisory-list">
          <li>Marai Larasi <span class="wwa-advisory-role">(Advocate, Activist and Consultant)</span></li>
          <li>Esme Peach <span class="wwa-advisory-role">(Creative Strategist)</span></li>
          <li>Rachel Barrett <span class="wwa-advisory-role">(Barrister at Cloisters)</span></li>
          <li>Kajal Odedra <span class="wwa-advisory-role">(Executive Director at Change.org UK)</span></li>
          <li>Ayesha Saran <span class="wwa-advisory-role">(Programme Manager at Barrow Cadbury)</span></li>
          <li>Sarah Lamble</li>
        </ul>
      </div>
      <div class="wwa-advisory-col">
        <h2 class="wwa-advisory-title">Co-Founders</h2>
        <ul class="wwa-advisory-list">
          <li>Carys Afoko</li>
          <li>Sondhya Gupta</li>
          <li>Rose Hall</li>
          <li>Hannah Lownsbrough</li>
          <li>Hanna Thomas</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="wwa-cta" aria-labelledby="wwa-cta-heading">
    <div class="wwa-cta-inner">
      <h2 id="wwa-cta-heading" class="wwa-cta-heading">Join the Level Up community</h2>
      <p class="wwa-cta-sub">Campaign updates, event invitations, and feminist thinking — straight to your inbox.</p>
      <a href="https://levelup.yourmovement.org/p/join-us" target="_blank" rel="noopener" class="wwa-cta-btn">JOIN US</a>
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  .wwa-hero,
  .wwa-team,
  .wwa-advisory,
  .wwa-cta {
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  /* Hero */
  .wwa-hero {
    background: #0C0A3E;
    padding: 100px 24px 80px;
  }
  .wwa-hero-inner { max-width: 900px; margin: 0 auto; }
  .wwa-eyebrow {
    display: inline-block;
    font: 700 11px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #A89CED;
    margin-bottom: 24px;
  }
  .wwa-hero-title {
    font: 900 clamp(56px, 11vw, 120px)/0.9 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.05em;
    margin: 0 0 32px;
  }
  .wwa-hero-subtitle {
    font: 400 20px/1.6 'DM Sans', sans-serif;
    color: rgba(238,235,211,0.7);
    max-width: 560px;
    margin: 0;
  }

  /* Team grid */
  .wwa-team {
    background: #EEEBD3;
    padding: 80px 24px 96px;
  }
  .wwa-team-inner { max-width: 1100px; margin: 0 auto; }
  .wwa-team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px 32px;
  }

  .wwa-card {
    display: flex;
    flex-direction: column;
  }

  /* Photo placeholder */
  .wwa-card-photo {
    width: 100%;
    aspect-ratio: 3/4;
    background: #0C0A3E;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .wwa-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .wwa-initials {
    font: 800 32px/1 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: 0.02em;
  }

  .wwa-card-name {
    font: 800 18px/1.15 'DM Sans', sans-serif;
    color: #0C0A3E;
    letter-spacing: -0.02em;
    margin: 0 0 6px;
  }
  .wwa-card-role {
    font: 700 11px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #A89CED;
    margin: 0 0 12px;
  }
  .wwa-card-fun {
    font: 400 14px/1.6 'DM Sans', sans-serif;
    color: rgba(12,10,62,0.6);
    margin: 0;
    flex: 1;
  }
  .wwa-linkedin {
    display: inline-flex;
    align-items: center;
    color: #0C0A3E;
    margin-top: 12px;
    transition: color 0.15s;
  }
  .wwa-linkedin:hover { color: #A89CED; }

  /* Advisory */
  .wwa-advisory {
    background: #0C0A3E;
    padding: 80px 24px 96px;
  }
  .wwa-advisory-inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }
  .wwa-advisory-title {
    font: 900 clamp(18px,2.5vw,24px)/1.05 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    padding-bottom: 16px;
    border-bottom: 2px solid #CCFF33;
  }
  .wwa-advisory-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .wwa-advisory-list li {
    font: 700 15px/1.4 'DM Sans', sans-serif;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .wwa-advisory-role {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: rgba(238,235,211,0.7);
    font-size: 13px;
  }

  /* CTA */
  .wwa-cta {
    background: #CCFF33;
    padding: 96px 24px;
    text-align: center;
  }
  .wwa-cta-inner { max-width: 640px; margin: 0 auto; }
  .wwa-cta-heading {
    font: 900 clamp(32px,5vw,52px)/1.05 'DM Sans', sans-serif;
    color: #0C0A3E;
    letter-spacing: -0.04em;
    margin: 0 0 20px;
  }
  .wwa-cta-sub {
    font: 400 17px/1.65 'DM Sans', sans-serif;
    color: rgba(12,10,62,0.7);
    margin: 0 0 36px;
  }
  .wwa-cta-btn {
    display: inline-block;
    font: 800 13px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: #0C0A3E;
    color: #CCFF33;
    text-decoration: none;
    padding: 18px 40px;
    transition: background 0.15s;
  }
  .wwa-cta-btn:hover { background: #EEEBD3; color: #0C0A3E; }

  @media (max-width: 1024px) {
    .wwa-team-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .wwa-team-grid { grid-template-columns: repeat(2, 1fr); gap: 32px 20px; }
    .wwa-advisory-inner { grid-template-columns: 1fr; gap: 48px; }
  }
  @media (max-width: 480px) {
    .wwa-team-grid { grid-template-columns: 1fr 1fr; gap: 24px 16px; }
  }
</style>
