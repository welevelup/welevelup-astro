---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { extract } from '../../lib/extractHtml';
import homeRaw from '../../_clone/index.html?raw';

const { headInner, bodyClass } = extract(homeRaw);
---
<Layout
  headHtml={headInner}
  bodyClass={bodyClass}
  title="Thank You for Your Donation | Level Up"
  description="Thank you for supporting Level Up's feminist campaigns. Your contribution helps us fight for gender justice in the UK."
>
  <Nav />

  <main class="lu-thanks">
    <div class="lu-thanks__hero">
      <p class="lu-thanks__label">Donation received</p>
      <h1 class="lu-thanks__heading">Thank you<br/>for standing<br/>with us.</h1>
    </div>

    <div class="lu-thanks__body">
      <div class="lu-thanks__message">
        <p>Your donation is being processed. You'll receive a confirmation email shortly.</p>
        <p>If you set up a monthly donation, your subscription starts once this first payment clears — usually within minutes for cards.</p>
      </div>

      <div class="lu-thanks__impact">
        <p class="lu-thanks__impact-label">Your donation powers</p>
        <ul class="lu-thanks__list">
          <li>Campaigns for abortion decriminalisation in England and Wales</li>
          <li>Ending the imprisonment of pregnant women</li>
          <li>Dignified media coverage of domestic abuse deaths</li>
          <li>Community bystander training — We Protect Us</li>
        </ul>
      </div>

      <div class="lu-thanks__actions">
        <a href="/active-campaigns" class="lu-thanks__btn-primary">See our campaigns →</a>
        <a href="/" class="lu-thanks__btn-secondary">Back to home</a>
      </div>

      <p class="lu-thanks__contact">Questions? <a href="mailto:hello@welevelup.org">hello@welevelup.org</a></p>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .lu-thanks {
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .lu-thanks__hero {
    background: #0C0A3E;
    padding: 80px 40px 72px;
  }

  .lu-thanks__label {
    margin: 0 0 20px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #CCFF33;
  }

  .lu-thanks__heading {
    margin: 0;
    font-size: clamp(48px, 8vw, 88px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: #EEEBD3;
  }

  .lu-thanks__body {
    max-width: 640px;
    padding: 64px 40px 96px;
  }

  .lu-thanks__message p {
    font-size: 18px;
    line-height: 1.6;
    color: #333;
    margin: 0 0 16px;
  }

  .lu-thanks__impact {
    margin-top: 48px;
    padding: 32px;
    background: #EEEBD3;
    border-left: 4px solid #CCFF33;
  }

  .lu-thanks__impact-label {
    margin: 0 0 16px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0C0A3E;
  }

  .lu-thanks__list {
    margin: 0;
    padding: 0 0 0 20px;
    list-style: disc;
  }

  .lu-thanks__list li {
    font-size: 15px;
    line-height: 1.8;
    color: #333;
  }

  .lu-thanks__actions {
    margin-top: 48px;
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .lu-thanks__btn-primary {
    background: #0C0A3E;
    color: #CCFF33;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    padding: 16px 32px;
    display: inline-block;
  }

  .lu-thanks__btn-secondary {
    font-size: 14px;
    font-weight: 700;
    color: #0C0A3E;
    text-decoration: none;
    border-bottom: 2px solid #0C0A3E;
    padding-bottom: 2px;
  }

  .lu-thanks__contact {
    margin-top: 48px;
    font-size: 14px;
    color: #888;
  }

  .lu-thanks__contact a {
    color: #0C0A3E;
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .lu-thanks__hero {
      padding: 56px 24px 48px;
    }
    .lu-thanks__body {
      padding: 48px 24px 72px;
    }
  }
</style>
