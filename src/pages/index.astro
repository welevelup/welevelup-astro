---
import Layout from '../layouts/Layout.astro';
import { extract } from '../lib/extractHtml';
import rawHtml from '../_clone/index.html?raw';

const { headInner, bodyClass, bodyInner } = extract(rawHtml);
---
<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Fragment set:html={bodyInner} />
</Layout>
