---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { extract } from '../lib/extractHtml';
import rawHtml from '../_clone/index.html?raw';

const { headInner, bodyClass, mainContent } = extract(rawHtml);
---
<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />
  <Fragment set:html={mainContent} />
  <!-- PETITIONS SECTION -->
  <section class="home-petitions">
    <div class="home-petitions-inner">
      <h2 class="home-petitions-title">Sign Our Petitions</h2>
      <div class="home-petitions-grid">
        <a href="/active-campaigns/abortion-is-healthcare" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/10/Screenshot-2024-06-14-at-12-1.webp" alt="Abortion is Healthcare" loading="lazy" />
          <div class="home-petition-body">
            <h3>Abortion is Healthcare</h3>
            <span class="home-petition-supporters">6.1K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/pregnancy-in-prison" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/10/FREEBABIES3-1-scaled-1.webp" alt="Pregnancy in Prison" loading="lazy" />
          <div class="home-petition-body">
            <h3>Stop sending pregnant women to prison</h3>
            <span class="home-petition-supporters">13.1K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/nomorelyes-2" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/08/NML11-2.webp" alt="#NoMoreLyes" loading="lazy" />
          <div class="home-petition-body">
            <h3>#NoMoreLyes: Take toxic hair relaxers off the shelves</h3>
            <span class="home-petition-supporters">6.4K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/media-guidelines-domestic-abuse" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/08/image-5.webp" alt="Dignity for Dead Women" loading="lazy" />
          <div class="home-petition-body">
            <h3>IPSO: Dignity for Dead Women</h3>
            <span class="home-petition-supporters">29.2K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/sexual-violence-in-football" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/08/image-4.webp" alt="Sexual Violence in Football" loading="lazy" />
          <div class="home-petition-body">
            <h3>Premier League and FA</h3>
            <span class="home-petition-supporters">4.3K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/islington-council-finish-holloway-womens-centre" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2026/02/screenshot_2026-03-13_at_11.37.42_720.png" alt="Islington Council" loading="lazy" />
          <div class="home-petition-body">
            <h3>Islington Council: Fund Holloway Women's Centre</h3>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- BLOG SECTION -->
  <section class="home-blog">
    <div class="home-blog-inner">
      <span class="home-blog-label">From the Blog</span>
      <h2 class="home-blog-title">Feminist Thinking</h2>
      <div class="home-blog-grid">
        <a href="/blog/its-time-to-reclaim-the-socialist-roots-of-international-womens-day" class="home-blog-card home-blog-card--featured">
          <span class="home-blog-tag">Solidarity &amp; Movement</span>
          <h3>It's Time to Reclaim the Socialist Roots of International Women's Day</h3>
          <span class="home-blog-read">Read article →</span>
        </a>
        <a href="/blog/abortion-is-healthcare-why-decriminalisation-must-include-health-workers" class="home-blog-card">
          <span class="home-blog-tag">Reproductive Rights</span>
          <h3>Abortion Is Healthcare: Why Decriminalisation Must Include Health Workers</h3>
          <span class="home-blog-read">Read →</span>
        </a>
        <a href="/blog/ending-prison-for-pregnant-women-a-non-reformist-reform" class="home-blog-card">
          <span class="home-blog-tag">Criminalisation &amp; Justice</span>
          <h3>Ending Prison for Pregnant Women: A Non-Reformist Reform</h3>
          <span class="home-blog-read">Read →</span>
        </a>
        <a href="/blog/gender-critical-feminism-isnt-feminist" class="home-blog-card">
          <span class="home-blog-tag">Trans-Inclusive Feminism</span>
          <h3>"Gender-Critical" Feminism Isn't Feminist — It's Anti-Trans Politics</h3>
          <span class="home-blog-read">Read →</span>
        </a>
        <a href="/blog/why-the-media-should-focus-on-diddys-violence-not-his-kinks" class="home-blog-card">
          <span class="home-blog-tag">Media &amp; Violence</span>
          <h3>Why the Media Should Focus on Diddy's Violence, Not His Kinks</h3>
          <span class="home-blog-read">Read →</span>
        </a>
        <a href="/blog/why-we-need-to-start-moving-offline" class="home-blog-card">
          <span class="home-blog-tag">Solidarity &amp; Movement</span>
          <h3>Why We Need to Start Moving Offline</h3>
          <span class="home-blog-read">Read →</span>
        </a>
      </div>
      <a href="/blog" class="home-blog-all">View all posts →</a>
    </div>
  </section>

  <section class="home-cta">
    <h2>Join the Level Up community</h2>
    <p>Campaign updates, event invitations, and feminist thinking — straight to your inbox.</p>
    <a href="https://levelup.yourmovement.org/p/join-us" class="home-cta-btn" target="_blank" rel="noopener">Join us</a>
  </section>
  <Footer />
</Layout>

<style is:global>
  .home-cta {
    background: #0C0A3E;
    padding: 80px 24px;
    text-align: center;
    font-family: 'DM Sans', sans-serif;
  }
  .home-cta h2 {
    font: 800 40px/0.9 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.04em;
    margin: 0 0 16px;
  }
  .home-cta p {
    font: 400 17px/1.5 'DM Sans', sans-serif;
    color: rgba(238, 235, 211, 0.6);
    max-width: 440px;
    margin: 0 auto 32px;
  }
  .home-cta-btn {
    display: inline-block;
    background: #CCFF33;
    color: #0C0A3E;
    font: 700 14px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 18px 40px;
    text-decoration: none;
  }
  .home-cta-btn:hover { background: #fff; }

  /* ── Petitions section ───────────────────────────────── */
  .home-petitions {
    background: #0C0A3E;
    padding: 80px 24px;
    font-family: 'DM Sans', sans-serif;
  }
  .home-petitions-inner { max-width: 1100px; margin: 0 auto; }
  .home-petitions-title {
    font: 800 48px/0.9 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.04em;
    margin: 0 0 40px;
    text-align: center;
  }
  .home-petitions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .home-petition-card {
    background: rgba(238,235,211,0.04);
    border: 1px solid rgba(238,235,211,0.08);
    text-decoration: none;
    overflow: hidden;
    transition: all 0.2s;
  }
  .home-petition-card:hover {
    border-color: #CCFF33;
    transform: translateY(-4px);
  }
  .home-petition-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }
  .home-petition-body {
    padding: 20px;
  }
  .home-petition-body h3 {
    font: 700 17px/1.2 'DM Sans', sans-serif;
    color: #EEEBD3;
    margin: 0 0 8px;
  }
  .home-petition-supporters {
    font: 600 12px/1 'DM Sans', sans-serif;
    color: #CCFF33;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  @media (max-width: 768px) {
    .home-petitions-grid { grid-template-columns: 1fr; }
    .home-petitions-title { font-size: 36px; }
  }

  /* Hide empty "Next Event" section */
  .elementor-element-684b07bb,
  .elementor-element-484edde0,
  [data-id="684b07bb"],
  [data-id="484edde0"] {
    display: none !important;
  }
  /* Hide duplicate "Join the Level Up Community" purple CTA section */
  [data-id="585520af"] {
    display: none !important;
  }
  /* Hide clone's broken blog section */
  [data-id="0362161"] {
    display: none !important;
  }
  /* Hide clone's broken petitions section */
  [data-id="9f5db00"] {
    display: none !important;
  }

  /* ── Blog section ────────────────────────────────────── */
  .home-blog {
    background: #0C0A3E;
    padding: 80px 24px;
    font-family: 'DM Sans', sans-serif;
  }
  .home-blog-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .home-blog-label {
    font: 600 12px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #A89CED;
    display: block;
    margin-bottom: 12px;
  }
  .home-blog-title {
    font: 800 48px/0.9 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.04em;
    margin: 0 0 40px;
  }
  .home-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .home-blog-card {
    background: rgba(238, 235, 211, 0.04);
    padding: 32px 28px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(238, 235, 211, 0.06);
    transition: all 0.2s;
    min-height: 180px;
  }
  .home-blog-card:hover {
    background: rgba(238, 235, 211, 0.08);
    border-color: #CCFF33;
  }
  .home-blog-card--featured {
    grid-column: 1 / -1;
    background: rgba(204, 255, 51, 0.08);
    border-color: rgba(204, 255, 51, 0.15);
    min-height: auto;
    padding: 40px 32px;
  }
  .home-blog-card--featured h3 {
    font-size: 28px !important;
  }
  .home-blog-tag {
    font: 600 10px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #A89CED;
  }
  .home-blog-card h3 {
    font: 700 18px/1.2 'DM Sans', sans-serif;
    color: #CCFF33;
    margin: 0;
    flex: 1;
  }
  .home-blog-read {
    font: 600 13px/1 'DM Sans', sans-serif;
    color: #CCFF33;
    margin-top: auto;
  }
  .home-blog-all {
    display: inline-block;
    margin-top: 32px;
    font: 700 14px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #CCFF33;
    text-decoration: none;
  }
  .home-blog-all:hover { color: #FFFFFF; }

  @media (max-width: 768px) {
    .home-blog-grid { grid-template-columns: 1fr; }
    .home-blog-card--featured { grid-column: 1; }
    .home-blog-title { font-size: 36px; }
  }
</style>

<script>
  // Force lazy-loaded images (WP Smush uses data-src)
  document.querySelectorAll('img[data-src]').forEach((img) => {
    const dataSrc = img.getAttribute('data-src');
    if (dataSrc) img.setAttribute('src', dataSrc);
  });

  // Force lazy iframes (videos, embeds)
  document.querySelectorAll('iframe[data-src]').forEach((iframe) => {
    const dataSrc = iframe.getAttribute('data-src');
    if (dataSrc) iframe.setAttribute('src', dataSrc);
  });

  // Force background images from data-bg
  document.querySelectorAll('[data-bg]').forEach((el) => {
    const bg = el.getAttribute('data-bg');
    if (bg) (el as HTMLElement).style.backgroundImage = `url(${bg})`;
  });

  // Load srcset images
  document.querySelectorAll('img[data-srcset]').forEach((img) => {
    const srcset = img.getAttribute('data-srcset');
    if (srcset) img.setAttribute('srcset', srcset);
  });

  // Load Elementor video widgets (youtube embeds stored in data-settings)
  document.querySelectorAll('.elementor-widget-video').forEach((widget) => {
    const settings = widget.querySelector('[data-settings]')?.getAttribute('data-settings');
    if (!settings) return;
    try {
      const parsed = JSON.parse(settings);
      const url = parsed.youtube_url;
      if (!url) return;
      const videoId = url.match(/(?:youtu\.be\/|v=)([^&?/]+)/)?.[1];
      if (!videoId) return;
      const container = widget.querySelector('.elementor-video') || widget.querySelector('.elementor-wrapper') || widget;
      if (!container.querySelector('iframe')) {
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube.com/embed/${videoId}?controls=1`;
        iframe.style.cssText = 'width:100%;aspect-ratio:16/9;border:none;';
        iframe.allow = 'accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture';
        iframe.allowFullscreen = true;
        container.appendChild(iframe);
      }
    } catch {}
  });
</script>
