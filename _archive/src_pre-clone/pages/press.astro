---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Level Up Press Coverage | Feminist Campaigning in the UK"
  description="Explore media coverage of Level Up, a UK-based feminist campaigning organisation working on reproductive justice, abortion decriminalisation and gender justice."
>

<!-- Hero Banner -->
<section id="sub-page-hero-banner">
  <div class="hero-inner">
    <h2 class="page-title">Press Coverage | Level Up UK</h2>
  </div>
</section>

<style>
  /* ── Hero ───────────────────────────────────────────── */
  #sub-page-hero-banner {
    background-color: #0C0A3E;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1.8em 0;
  }

  .hero-inner {
    max-width: 1200px;
    width: 100%;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 3vw;
    font-weight: 700;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
    margin: 0;
  }

  @media (max-width: 1024px) {
    #sub-page-hero-banner {
      padding: 3.5rem 0;
    }
    .page-title {
      font-size: 2.5vw;
    }
  }

  @media (max-width: 767px) {
    .page-title {
      font-size: 7vw;
    }
  }

  /* ── Page Container ─────────────────────────────────── */
  .page-container {
    font-family: 'DM Sans', sans-serif;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .page-container * {
    font-family: 'DM Sans', sans-serif;
  }

  /* ── Filter Buttons ─────────────────────────────────── */
  .filter-buttons {
    display: flex;
    gap: 8px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .filter-buttons button {
    padding: 10px 16px;
    background: transparent;
    border: 1px solid #0C0A3E;
    border-radius: 0;
    color: #0C0A3E;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 14px;
  }

  .filter-buttons button.active,
  .filter-buttons button:hover {
    background: #0C0A3E;
    color: #fff;
  }

  /* ── Grid ───────────────────────────────────────────── */
  .press-posts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }

  /* ── Cards ──────────────────────────────────────────── */
  .press-post {
    position: relative;
    height: 380px;
    border-radius: 18px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
    transition: transform 0.32s ease, box-shadow 0.32s ease;
    text-decoration: none;
  }

  .press-post:hover {
    transform: translateY(-8px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }

  .press-post::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(12, 10, 62, 0.30) 0%,
      rgba(12, 10, 62, 0.16) 45%,
      rgba(0, 0, 0, 0.04) 100%
    );
    z-index: 1;
  }

  .press-post a {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    text-decoration: none;
    color: #fff;
    position: relative;
    z-index: 2;
  }

  .press-overlay {
    width: 100%;
    margin: 14px;
    padding: 16px 16px 14px;
    border-radius: 16px;
    background: rgba(12, 10, 62, 0.38);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .press-post h2 {
    margin: 0 0 10px;
    font-size: 1.18rem;
    line-height: 1.15;
    color: #fff;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.28);
    font-weight: 600;
  }

  .press-post p {
    margin: 0 0 12px;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.22);
    font-weight: 400;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .press-date {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.88);
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 1024px) {
    .press-posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .press-posts-grid {
      grid-template-columns: 1fr;
    }
    .press-post {
      height: 330px;
    }
  }
</style>

