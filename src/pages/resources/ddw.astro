import homeRaw from '../../_clone/index.html?raw';
const { headInner, bodyClass } = extract(homeRaw);
---

<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Dignity for Dead Women — Media Guidelines & Resources",
    "description": "A curated collection of guidelines, research, and resources on responsible media reporting of domestic abuse deaths, compiled by Level Up's Dignity for Dead Women campaign.",
    "url": "https://welevelup.org/resources/ddw",
    "publisher": { "@type": "Organization", "name": "Level Up", "url": "https://welevelup.org" },
    "about": { "@type": "Thing", "name": "Media reporting of fatal domestic abuse" }
  })}</script>

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Dignity for Dead Women campaign?",
        "acceptedAnswer": { "@type": "Answer", "text": "Dignity for Dead Women (DDW) is a Level Up campaign launched in 2018 to challenge harmful and inaccurate media reporting on fatal domestic abuse and domestic homicide. The campaign produced the UK's first media guidelines on how to report domestic abuse deaths, endorsed by both press regulators IPSO and IMPRESS. Level Up has since trained over 500 journalists using the AIDA framework — Accountability, Images, Dignity, Accuracy." }
      },
      {
        "@type": "Question",
        "name": "Why does media reporting of domestic abuse deaths matter?",
        "acceptedAnswer": { "@type": "Answer", "text": "Every three days in the UK, a woman is killed by a partner or ex-partner. Media coverage frequently misrepresents these killings as isolated incidents or 'crimes of passion', rather than the predictable outcome of sustained coercive control. Irresponsible reporting reinforces myths that keep killing women and adds to the trauma of bereaved families. Level Up's research found that 2 in 3 families bereaved by domestic homicide had their grieving process negatively impacted by media coverage." }
      },
      {
        "@type": "Question",
        "name": "What are the Level Up media guidelines?",
        "acceptedAnswer": { "@type": "Answer", "text": "Level Up's media guidelines provide journalists with evidence-based guidance on how to report fatal domestic abuse accurately, responsibly, and with dignity. They are built around the AIDA acronym: Accountability (name the perpetrator's choices), Images (choose photos that don't sexualise or criminalise the victim), Dignity (centre the victim's life, not just their death), and Accuracy (reflect the reality of coercive control). The guidelines are endorsed by IPSO and IMPRESS." }
      },
      {
        "@type": "Question",
        "name": "What is IPSO and why is it relevant to this campaign?",
        "acceptedAnswer": { "@type": "Answer", "text": "IPSO (the Independent Press Standards Organisation) is the UK's main press regulator, whose Editor's Code of Practice is legally binding on member newsrooms. Level Up's Dignity for Dead Women campaign has lobbied IPSO since 2018 to introduce a specific clause on fatal domestic abuse reporting. In 2023, Level Up delivered a petition signed by over 26,700 people to IPSO headquarters, accompanied by a formal submission to the IPSO Editor's Code Committee review calling for a sub-clause to Clause 4." }
      },
      {
        "@type": "Question",
        "name": "What is the AIDA framework for reporting domestic abuse?",
        "acceptedAnswer": { "@type": "Answer", "text": "AIDA stands for Accountability, Images, Dignity, and Accuracy — a four-point framework developed by Level Up to help journalists report fatal domestic abuse responsibly. Accountability means naming the perpetrator's choices as choices. Images means avoiding photos that sexualise victims or humanise perpetrators at the expense of victims. Dignity means focusing on the victim's life, relationships, and personhood. Accuracy means reflecting that domestic homicide is the outcome of sustained coercive control, not a spontaneous act of passion." }
      },
      {
        "@type": "Question",
        "name": "How can journalists access training on reporting fatal domestic abuse?",
        "acceptedAnswer": { "@type": "Answer", "text": "Level Up offers CPD-accredited training for journalists on reporting fatal domestic abuse, developed in partnership with domestic abuse training service AVA. Training sessions feature testimony from domestic abuse survivors and victims' families and are co-facilitated by award-winning journalist Helena Wadia. To book a training for yourself or your newsroom, contact mediasupport@welevelup.org. Level Up has trained over 500 journalists to date." }
      }
    ]
  })}</script>

  <section class="nr-hero" aria-labelledby="nr-hero-heading">
    <div class="nr-hero-inner">
      <div class="nr-hero-text">
        <span class="nr-eyebrow">Dignity for Dead Women</span>
        <h1 id="nr-hero-heading" class="nr-hero-title">Media Guidelines<br/>&amp; Resources</h1>
        <p class="nr-hero-subtitle">Reporting guidance and research on media coverage of domestic abuse victims.</p>
      </div>
      <div class="nr-hero-image" aria-hidden="true">
        <img src="https://welevelup.org/wp-content/uploads/2025/08/129483790_nomorelyes_final-21-credit_yvonnee.maxwell-2.jpg" alt="Dignity for Dead Women campaign — Level Up media guidelines for reporting fatal domestic abuse" loading="eager" />
      </div>
    </div>
  </section>

  <section class="nr-intro" aria-label="About this resource collection">
    <div class="nr-intro-inner">
      <p>In consultation with a coalition of domestic violence experts and victims' families, Level Up produced the UK's first media guidelines on how to report domestic abuse deaths. Endorsed by both press regulators IPSO and IMPRESS, the guidelines challenge headlines that frame femicide as "crimes of passion" rather than the predictable outcome of sustained coercive control.</p>
      <p>Every three days in the UK, a woman is killed by a partner or ex-partner. Level Up's research found that 2 in 3 families bereaved by domestic homicide had their grieving process negatively impacted by irresponsible media coverage. We have compiled the key guidelines, research, academic evidence, and regulatory submissions from the Dignity for Dead Women campaign in one place.</p>
      <p>Level Up has trained over 500 journalists using our AIDA framework — Accountability, Images, Dignity, Accuracy. If you come across relevant journalism, research, or guidance on this issue, please share it with us so we can add it to the collection.</p>
      <a href="https://welevelup.org/petition/dignity-for-dead-women/" target="_blank" rel="noopener" class="nr-intro-btn">Sign the petition →</a>
    </div>
  </section>

  <section class="nr-faq" aria-labelledby="nr-faq-heading">
    <div class="nr-faq-inner">
      <h2 id="nr-faq-heading" class="nr-faq-title">Common Questions</h2>
      <div class="nr-faq-list">
        <details class="nr-faq-item">
          <summary class="nr-faq-q">What is the Dignity for Dead Women campaign?</summary>
          <div class="nr-faq-a">Dignity for Dead Women (DDW) is a Level Up campaign launched in 2018 to challenge harmful and inaccurate media reporting on fatal domestic abuse. The campaign produced the UK's first media guidelines on reporting domestic abuse deaths, endorsed by both press regulators IPSO and IMPRESS. Level Up has trained over 500 journalists using the AIDA framework.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">Why does media reporting of domestic abuse deaths matter?</summary>
          <div class="nr-faq-a">Every three days in the UK, a woman is killed by a partner or ex-partner. Coverage framing these killings as "crimes of passion" rather than the outcome of coercive control reinforces the myths that keep killing women. Level Up's research found 2 in 3 bereaved families had their grieving process negatively impacted by media reporting.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">What are the Level Up media guidelines?</summary>
          <div class="nr-faq-a">Level Up's media guidelines provide journalists with evidence-based guidance built around the AIDA acronym: Accountability (name the perpetrator's choices), Images (choose photos that don't sexualise victims), Dignity (centre the victim's life, not just their death), and Accuracy (reflect the reality of coercive control). The guidelines are endorsed by IPSO and IMPRESS.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">What is IPSO and why is it relevant?</summary>
          <div class="nr-faq-a">IPSO is the UK's main press regulator whose Editor's Code of Practice is legally binding on member newsrooms. Level Up has lobbied IPSO since 2018 to add a specific clause on fatal domestic abuse reporting. In 2023, Level Up delivered a petition of over 26,700 signatures to IPSO headquarters with a formal submission to its Editor's Code Committee review.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">What is the AIDA framework?</summary>
          <div class="nr-faq-a">AIDA stands for Accountability, Images, Dignity, and Accuracy — a four-point framework to help journalists report fatal domestic abuse responsibly. It replaced an earlier six-point model and is now used as the basis of Level Up's CPD-accredited journalist training, co-facilitated with domestic abuse survivors and victims' families.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">How can journalists access training?</summary>
          <div class="nr-faq-a">Level Up offers CPD-accredited training developed with domestic abuse training service AVA. Sessions feature testimony from survivors and victims' families and are co-facilitated by award-winning journalist Helena Wadia. To book training for yourself or your newsroom, contact mediasupport@welevelup.org.</div>
        </details>
      </div>
    </div>
  </section>

  <section class="nr-body">
    <div class="nr-body-inner">

