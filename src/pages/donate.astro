---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { extract } from '../lib/extractHtml';
import homeRaw from '../_clone/index.html?raw';

const { headInner, bodyClass } = extract(homeRaw);
---
<Layout
  headHtml={headInner}
  bodyClass={bodyClass}
  title="Support Level Up | Donate to Feminist Campaigns in the UK"
  description="Every campaign started with someone like you. Support Level Up's feminist campaigns for gender justice in the UK — from abortion rights to ending violence against women."
  ogImage="https://welevelup.org/wp-content/uploads/2023/05/Level-Up-OG.png"
>
  <Nav />

  <main class="lu-donate">

    <!-- HERO -->
    <section class="lu-donate__hero">
      <div class="lu-donate__hero-inner">
        <span class="lu-donate__hero-label">Support the work</span>
        <h1 class="lu-donate__hero-title">Every campaign started<br/>with someone like you</h1>
        <p class="lu-donate__hero-sub">Level Up is a UK-based feminist campaigning organisation building people-powered movements. We run on small, regular donations from people who believe in gender justice.</p>
      </div>
    </section>

    <!-- IMPACT STATS -->
    <section class="lu-donate__impact">
      <div class="lu-donate__impact-inner">
        <h2 class="lu-donate__impact-title">Supported by people like you, Level Up has…</h2>
        <div class="lu-donate__impact-grid">
          <div class="lu-donate__impact-item">
            <span class="lu-donate__impact-icon">01</span>
            <p>Changed sentencing policy to prevent pregnant women going to prison</p>
          </div>
          <div class="lu-donate__impact-item">
            <span class="lu-donate__impact-icon">02</span>
            <p>Pushed the Premier League to issue consent training for football clubs</p>
          </div>
          <div class="lu-donate__impact-item">
            <span class="lu-donate__impact-icon">03</span>
            <p>Changed how the media reports on domestic homicide — ending victim-blaming headlines</p>
          </div>
          <div class="lu-donate__impact-item">
            <span class="lu-donate__impact-icon">04</span>
            <p>Trained 413 people in bystander intervention to interrupt harassment and violence</p>
          </div>
        </div>
      </div>
    </section>

    <!-- DONATE FORM -->
    <section class="lu-donate__form-section">
      <div class="lu-donate__form-wrap">
        <h2 class="lu-donate__form-title">Make a donation</h2>

        <form class="lu-donate__form" id="donate-form" novalidate>

          <fieldset class="lu-donate__field lu-donate__field--type">
            <legend>How would you like to give?</legend>
            <div class="lu-donate__toggle">
              <label class="lu-donate__toggle-opt">
                <input type="radio" name="frequency" value="monthly" checked />
                <span>Monthly</span>
              </label>
              <label class="lu-donate__toggle-opt">
                <input type="radio" name="frequency" value="one-time" />
                <span>One-off</span>
              </label>
            </div>
          </fieldset>

          <fieldset class="lu-donate__field lu-donate__field--amount">
            <legend>Choose an amount (GBP)</legend>
            <div class="lu-donate__amounts">
              <label><input type="radio" name="preset" value="5" /><span>£5</span></label>
              <label><input type="radio" name="preset" value="10" checked /><span>£10</span></label>
              <label><input type="radio" name="preset" value="15" /><span>£15</span></label>
              <label><input type="radio" name="preset" value="25" /><span>£25</span></label>
              <label><input type="radio" name="preset" value="custom" /><span>Other</span></label>
            </div>
            <label class="lu-donate__custom" hidden>
              <span>Enter amount</span>
              <input type="number" name="customAmount" min="1" step="1" placeholder="£" />
            </label>
          </fieldset>

          <fieldset class="lu-donate__field lu-donate__field--details">
            <legend>Your details</legend>
            <label>
              <span>Full name</span>
              <input type="text" name="donorName" autocomplete="name" />
            </label>
            <label>
              <span>Email address</span>
              <input type="email" name="donorEmail" autocomplete="email" required />
            </label>
          </fieldset>

          <div class="lu-donate__field lu-donate__field--giftaid">
            <p class="lu-donate__giftaid-title">Gift Aid (UK taxpayers)</p>
            <label class="lu-donate__giftaid-label">
              <input type="checkbox" name="giftAid" class="lu-donate__giftaid-check" />
              <span>I am a UK taxpayer and want Level Up to claim Gift Aid on this donation — at no extra cost to me, it increases the value by 25%.</span>
            </label>
          </div>

          <p class="lu-donate__error" id="donate-error" role="alert" hidden></p>

          <p class="lu-donate__cancel-note" id="cancel-note" hidden>Cancel anytime by emailing <a href="mailto:hello@welevelup.org">hello@welevelup.org</a> — no fuss.</p>

          <button type="submit" class="lu-donate__submit">
            Continue to secure payment →
          </button>

          <p class="lu-donate__legal">
            Payments are processed securely by Mollie. We don't store your card details.
          </p>
        </form>
      </div>
    </section>


  </main>

  <Footer />
</Layout>

<style is:global>
  .lu-donate {
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  /* HERO */
  .lu-donate__hero {
    background: #0C0A3E;
    padding: 80px 24px 64px;
    text-align: center;
  }
  .lu-donate__hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .lu-donate__hero-label {
    display: block;
    font: 600 11px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #A89CED;
    margin-bottom: 24px;
  }
  .lu-donate__hero-title {
    font: 800 clamp(36px, 7vw, 56px)/0.95 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
  }
  .lu-donate__hero-sub {
    font: 400 18px/1.6 'DM Sans', sans-serif;
    color: rgba(238, 235, 211, 0.7);
    max-width: 560px;
    margin: 0 auto;
  }

  /* IMPACT */
  .lu-donate__impact {
    background: #EEEBD3;
    padding: 64px 24px;
  }
  .lu-donate__impact-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .lu-donate__impact-title {
    font: 700 22px/1.3 'DM Sans', sans-serif;
    color: #0C0A3E;
    margin: 0 0 40px;
    text-align: center;
  }
  .lu-donate__impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .lu-donate__impact-item {
    background: #fff;
    padding: 28px 24px;
    border-left: 3px solid #A89CED;
  }
  .lu-donate__impact-icon {
    display: block;
    font: 800 13px/1 'DM Sans', sans-serif;
    color: #A89CED;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .lu-donate__impact-item p {
    font: 400 15px/1.6 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.8);
    margin: 0;
  }
  @media (max-width: 600px) {
    .lu-donate__impact-grid { grid-template-columns: 1fr; }
  }

  /* FORM SECTION */
  .lu-donate__form-section {
    background: #F5F3E8;
    padding: 64px 24px 80px;
  }
  .lu-donate__form-wrap {
    max-width: 520px;
    margin: 0 auto;
  }
  .lu-donate__form-title {
    font: 800 28px/1.1 'DM Sans', sans-serif;
    color: #0C0A3E;
    margin: 0 0 32px;
    letter-spacing: -0.02em;
  }
  .lu-donate__field {
    border: none;
    padding: 0;
    margin: 0 0 28px;
  }
  .lu-donate__field legend {
    font: 600 13px/1 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
    display: block;
  }
  .lu-donate__toggle {
    display: flex;
    border: 2px solid #0C0A3E;
    width: fit-content;
  }
  .lu-donate__toggle-opt { cursor: pointer; }
  .lu-donate__toggle-opt input { display: none; }
  .lu-donate__toggle-opt span {
    display: block;
    padding: 12px 28px;
    font: 600 14px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    transition: all 0.15s;
    cursor: pointer;
  }
  .lu-donate__toggle-opt input:checked + span {
    background: #0C0A3E;
    color: #CCFF33;
  }
  .lu-donate__amounts {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    margin-bottom: 12px;
  }
  .lu-donate__amounts label { cursor: pointer; }
  .lu-donate__amounts input { display: none; }
  .lu-donate__amounts span {
    display: block;
    text-align: center;
    padding: 14px 8px;
    border: 2px solid rgba(12, 10, 62, 0.2);
    font: 700 16px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    transition: all 0.15s;
    cursor: pointer;
  }
  .lu-donate__amounts input:checked + span {
    border-color: #0C0A3E;
    background: #0C0A3E;
    color: #CCFF33;
  }
  .lu-donate__custom { display: block; margin-top: 8px; }
  .lu-donate__custom span {
    display: block;
    font: 600 12px/1 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.6);
    margin-bottom: 6px;
  }
  .lu-donate__custom input {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid rgba(12, 10, 62, 0.2);
    font: 400 16px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    background: #fff;
    box-sizing: border-box;
  }
  .lu-donate__field--details label { display: block; margin-bottom: 16px; }
  .lu-donate__field--details span {
    display: block;
    font: 600 12px/1 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }
  .lu-donate__field--details input {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid rgba(12, 10, 62, 0.15);
    font: 400 16px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    background: #fff;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }
  .lu-donate__field--details input:focus {
    outline: none;
    border-color: #A89CED;
  }
  .lu-donate__error {
    color: #c0392b;
    font: 400 14px/1.4 'DM Sans', sans-serif;
    margin: 0 0 16px;
  }
  .lu-donate__submit {
    display: block;
    width: 100%;
    background: #0C0A3E;
    color: #CCFF33;
    font: 700 14px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 20px 32px;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
    margin-bottom: 20px;
  }
  .lu-donate__submit:hover { background: #A89CED; color: #0C0A3E; }
  .lu-donate__field--giftaid {
    border: 1px solid rgba(12,10,62,0.12);
    padding: 16px;
    margin: 0 0 24px;
    background: #fff;
    border-radius: 0;
  }
  .lu-donate__giftaid-title {
    font: 600 13px/1 'DM Sans', sans-serif;
    color: rgba(12,10,62,0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 12px;
  }
  .lu-donate__giftaid-label {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    cursor: pointer;
  }
  .lu-donate__giftaid-check {
    margin-top: 3px;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    accent-color: #0C0A3E;
  }
  .lu-donate__giftaid-label span {
    font: 400 13px/1.6 'DM Sans', sans-serif;
    color: rgba(12,10,62,0.75);
  }
  .lu-donate__cancel-note {
    font: 400 13px/1.5 'DM Sans', sans-serif;
    color: rgba(12,10,62,0.6);
    margin: 0 0 16px;
    text-align: center;
  }
  .lu-donate__cancel-note a { color: rgba(12,10,62,0.8); }
  .lu-donate__legal {
    font: 400 12px/1.6 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.5);
    margin: 0;
  }
  .lu-donate__legal a { color: rgba(12, 10, 62, 0.7); }

</style>

<script>
  const form = document.getElementById('donate-form') as HTMLFormElement;
  const errorEl = document.getElementById('donate-error') as HTMLParagraphElement;
  const cancelNote = document.getElementById('cancel-note') as HTMLParagraphElement;
  const customLabel = document.querySelector('.lu-donate__custom') as HTMLLabelElement;
  const customInput = document.querySelector('input[name="customAmount"]') as HTMLInputElement;

  function updateCancelNote() {
    const freq = (form.querySelector('input[name="frequency"]:checked') as HTMLInputElement)?.value;
    cancelNote.hidden = freq !== 'monthly';
  }
  updateCancelNote();
  document.querySelectorAll('input[name="frequency"]').forEach(r => r.addEventListener('change', updateCancelNote));

  document.querySelectorAll('input[name="preset"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      const val = (e.target as HTMLInputElement).value;
      customLabel.hidden = val !== 'custom';
      if (val === 'custom') customInput.focus();
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.hidden = true;

    const freq = (form.querySelector('input[name="frequency"]:checked') as HTMLInputElement)?.value;
    const preset = (form.querySelector('input[name="preset"]:checked') as HTMLInputElement)?.value;
    const amount = preset === 'custom' ? customInput.value : preset;
    const donorName = (form.querySelector('input[name="donorName"]') as HTMLInputElement)?.value ?? '';
    const donorEmail = (form.querySelector('input[name="donorEmail"]') as HTMLInputElement)?.value ?? '';

    if (!donorEmail) {
      errorEl.textContent = 'Please enter your email address.';
      errorEl.hidden = false;
      return;
    }
    if (preset === 'custom' && (!amount || Number(amount) < 1)) {
      errorEl.textContent = 'Please enter a valid amount.';
      errorEl.hidden = false;
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Processing…';

    try {
      const res = await fetch('/api/create-donation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          amount: String(amount),
          recurring: freq === 'monthly',
          donorName,
          donorEmail,
          giftAid: (form.querySelector('input[name="giftAid"]') as HTMLInputElement)?.checked ?? false,
        }),
      });

      const data = await res.json();
      if (!res.ok || !data.checkoutUrl) {
        throw new Error(data.error || 'Something went wrong. Please try again.');
      }

      window.location.href = data.checkoutUrl;
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      errorEl.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Continue to secure payment →';
    }
  });
</script>
