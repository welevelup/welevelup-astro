          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">The Guardian</span></span>
            <h3 class="pc-card-title" itemprop="headline">Pregnant women and new mothers shouldn’t be sent to jail, UK public says</h3>
            <p class="pc-card-desc">Poll shared with Observer shows high support for reform of prison sentencing to stop lives being torn apartar</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2024-02-24" itemprop="datePublished">February 24, 2024</time>
              <span class="pc-tag" style="--tag-color:#CCFF33">Pregnancy in Prison</span>
            </div>
          </div>
          <meta itemprop="url" content="https://www.theguardian.com/society/2024/feb/24/pregnant-women-and-new-mothers-shouldnt-be-sent-to-jail-uk-public-says" />
