---
/**
 * All campaign pages except pregnancy-in-prison (which has its own file).
 * Uses Nav/Footer components + real content from clone via set:html.
 * Zero text changes. Editorial styling via CSS.
 */
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { extract } from '../../lib/extractHtml';

export async function getStaticPaths() {
  const { readdirSync } = await import('node:fs');
  const { join } = await import('node:path');
  const cloneDir = join(process.cwd(), 'src/_clone/active-campaigns');
  const dirs = readdirSync(cloneDir, { withFileTypes: true })
    .filter((d: any) => d.isDirectory() && d.name !== 'pregnancy-in-prison')
    .map((d: any) => d.name);
  return dirs.map((s: string) => ({
    params: { slug: s },
    props: { file: join(cloneDir, s, 'index.html') },
  }));
}

const { readFileSync } = await import('node:fs');
const { file } = Astro.props;
const rawHtml = readFileSync(file, 'utf-8');
const { headInner, bodyClass, mainContent } = extract(rawHtml);
---
<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />
  <div class="campaign-content">
    <Fragment set:html={mainContent} />
  </div>
  <section class="cp-cta">
    <h2>Join the Level Up community</h2>
    <p>Campaign updates, event invitations, and feminist thinking — straight to your inbox.</p>
    <a href="https://levelup.yourmovement.org/p/join-us" class="cp-btn" target="_blank" rel="noopener">Join us</a>
  </section>
  <Footer />
</Layout>

<style is:global>
  .campaign-content {
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  /* Hero */
  .campaign-content > [data-elementor-type="wp-page"] > .e-con:first-child {
    background: #0C0A3E !important;
    padding: 80px 24px 64px !important;
  }
  .campaign-content > [data-elementor-type="wp-page"] > .e-con:first-child .e-con-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .campaign-content .page-title .elementor-heading-title {
    font: 800 clamp(48px, 10vw, 80px)/0.9 'DM Sans', sans-serif !important;
    letter-spacing: -0.045em !important;
    color: #CCFF33 !important;
    margin-bottom: 24px !important;
  }
  .campaign-content > [data-elementor-type="wp-page"] > .e-con:first-child p {
    color: rgba(238,235,211,0.7) !important;
    font-size: 18px !important;
    line-height: 1.5 !important;
  }
  .campaign-content > [data-elementor-type="wp-page"] > .e-con:first-child b,
  .campaign-content > [data-elementor-type="wp-page"] > .e-con:first-child strong {
    color: #EEEBD3 !important;
  }
  /* Petition button */
  .campaign-content .sign-petition-link,
  .campaign-content #sign-the-petition-block a {
    display: inline-block !important;
    background: #CCFF33 !important;
    color: #0C0A3E !important;
    font: 700 14px/1 'DM Sans', sans-serif !important;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    padding: 18px 36px !important;
    text-decoration: none !important;
    border: none !important;
  }
  .campaign-content .sign-petition-link:hover,
  .campaign-content #sign-the-petition-block a:hover { background: #fff !important; }
  .campaign-content #sign-the-petition-block h2 { display: none !important; }
  /* Section labels */
  .campaign-content .sub-title .elementor-heading-title {
    font: 700 13px/1 'DM Sans', sans-serif !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    color: #A89CED !important;
    padding-bottom: 8px !important;
    border-bottom: 2px solid #A89CED !important;
    display: inline-block !important;
  }
  /* Content sections */
  .campaign-content > [data-elementor-type="wp-page"] > .e-con {
    padding: 56px 24px !important;
  }
  .campaign-content > [data-elementor-type="wp-page"] > .e-con .e-con-inner {
    max-width: 900px !important;
    margin: 0 auto !important;
  }
  .campaign-content > [data-elementor-type="wp-page"] > .e-con:nth-child(odd) { background: #EEEBD3 !important; }
  .campaign-content > [data-elementor-type="wp-page"] > .e-con:nth-child(even) { background: #fff !important; }
  .campaign-content > [data-elementor-type="wp-page"] > .e-con:first-child { background: #0C0A3E !important; }
  /* Body text */
  .campaign-content .elementor-widget-text-editor p {
    font: 400 18px/1.6 'DM Sans', sans-serif !important;
    letter-spacing: -0.02em !important;
    color: rgba(12,10,62,0.8) !important;
    margin-bottom: 16px !important;
  }
  .campaign-content .elementor-widget-text-editor a {
    color: #0C0A3E !important;
    text-decoration: underline !important;
    text-decoration-color: #A89CED !important;
    text-underline-offset: 3px !important;
  }
  .campaign-content .elementor-widget-text-editor a:hover { text-decoration-color: #CCFF33 !important; }
  /* Year headings */
  .campaign-content .year-heading .elementor-heading-title {
    font: 800 36px/1 'DM Sans', sans-serif !important;
    letter-spacing: -0.03em !important;
    color: #0C0A3E !important;
    padding-left: 24px !important;
    border-left: 4px solid #CCFF33 !important;
  }
  /* Images */
  .campaign-content .elementor-widget-image img,
  .campaign-content .elementor-image img {
    width: 100% !important;
    height: auto !important;
    object-fit: cover !important;
    border-radius: 0 !important;
    margin: 24px 0 !important;
  }
  /* All headings */
  .campaign-content .elementor-heading-title {
    font-family: 'DM Sans', sans-serif !important;
    letter-spacing: -0.03em !important;
  }
  /* CTA */
  .cp-cta {
    background: #0C0A3E;
    padding: 80px 24px;
    text-align: center;
    font-family: 'DM Sans', sans-serif;
  }
  .cp-cta h2 {
    font: 800 40px/0.9 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.04em;
    margin: 0 0 16px;
  }
  .cp-cta p {
    font: 400 17px/1.5 'DM Sans', sans-serif;
    color: rgba(238,235,211,0.6);
    max-width: 440px;
    margin: 0 auto 32px;
  }
  .cp-btn {
    display: inline-block;
    background: #CCFF33;
    color: #0C0A3E;
    font: 700 14px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 18px 40px;
    text-decoration: none;
  }
  .cp-btn:hover { background: #fff; }
  @media (max-width: 768px) {
    .campaign-content .page-title .elementor-heading-title { font-size: 48px !important; }
    .campaign-content .year-heading .elementor-heading-title { font-size: 28px !important; }
  }
</style>
