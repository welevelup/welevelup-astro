---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { extract } from '../lib/extractHtml';
import homeRaw from '../_clone/index.html?raw';
const { headInner, bodyClass } = extract(homeRaw);
---
<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Level Up Press Coverage",
    "description": "Media coverage of Level Up feminist campaigns: ending pregnancy in prison, removing toxic chemicals from hair relaxers, tackling sexual violence in football, and reforming domestic abuse media reporting.",
    "url": "https://welevelup.org/press/",
    "publisher": {
      "@type": "Organization",
      "name": "Level Up",
      "url": "https://welevelup.org",
      "sameAs": ["https://www.facebook.com/levelupaction", "https://twitter.com/levelupaction"]
    },
    "mainEntity": {
      "@type": "ItemList",
      "name": "Level Up Press Coverage",
      "numberOfItems": 101,
      "itemListElement": [
    {"@type":"ListItem","position":1,"url":"https://www.thetimes.com/article/85026ca4-a398-41a2-838e-4917f6595e2b","name":"Prisoners who gave birth in handcuffs sue Ministry of Justice"},
    {"@type":"ListItem","position":2,"url":"https://www.voice-online.co.uk/news/uk-news/2025/05/27/black-women-call-for-a-ban-on-toxic-hair-products-linked-to-cancer/","name":"Black women call for a ban on toxic hair products linked to cancer - Voice Online"},
    {"@type":"ListItem","position":3,"url":"https://www.counselmagazine.co.uk/articles/sentencing-of-pregnant-women-a-21st-century-approach","name":"Sentencing of pregnant women: a 21st century approach"},
    {"@type":"ListItem","position":4,"url":"https://metro.co.uk/2025/02/22/pregnant-prison-i-thought-baby-died-treated-like-inconvenience-22578382/","name":"Pregnant in prison: 'When I thought my baby had died nobody seemed to care'"},
    {"@type":"ListItem","position":5,"url":"https://www.channel4.com/news/a-mothers-fight-for-justice-after-baby-dies-in-prison","name":"A mother’s fight for justice after baby dies in prison"},
    {"@type":"ListItem","position":6,"url":"https://www.theguardian.com/society/2025/feb/23/alarming-data-reveals-high-diabetes-risk-for-pregnant-women-in-english-jails","name":"Alarming data reveals high diabetes risk for pregnant women in English jails"},
    {"@type":"ListItem","position":7,"url":"https://www.thetimes.com/uk/crime/article/pregnant-women-prison-birth-handcuffed-male-officers-5f0698ks8","name":"Prisoners forced to give birth handcuffed to male officers"},
    {"@type":"ListItem","position":8,"url":"https://www.channel4.com/news/prison-will-never-be-a-safe-place-to-be-pregnant-campaigner","name":"‘Prison will never be a safe place to be pregnant’ – campaigner"},
    {"@type":"ListItem","position":9,"url":"https://www.theguardian.com/society/2021/sep/22/damning-report-published-into-death-of-baby-born-to-teenager-in-prison-cell","name":"Damning report published into death of baby born to teenager in prison cell"},
    {"@type":"ListItem","position":10,"url":"https://www.theguardian.com/society/2024/jan/19/pregnant-woman-jail-sentence-quashed-in-landmark-uk-ruling","name":"Pregnant woman’s jail sentence quashed in ‘landmark’ UK ruling"},
    {"@type":"ListItem","position":11,"url":"https://www.theguardian.com/society/2024/feb/24/pregnant-women-and-new-mothers-shouldnt-be-sent-to-jail-uk-public-says","name":"Pregnant women and new mothers shouldn’t be sent to jail, UK public says"},
    {"@type":"ListItem","position":12,"url":"https://www.theguardian.com/society/2023/oct/28/revealed-one-in-three-jailed-pregnant-women-in-england-and-wales-still-to-face-trial","name":"Revealed: one in three jailed pregnant women in England and Wales still to face trial"},
    {"@type":"ListItem","position":13,"url":"https://www.theguardian.com/society/2023/apr/21/loreal-urged-to-withdraw-hair-relaxers-after-studies-find-cancer-risk","name":"L’Oréal urged to withdraw hair relaxers after studies find cancer risk"},
    {"@type":"ListItem","position":14,"url":"https://www.theguardian.com/society/2022/sep/24/urgent-call-for-review-into-sentencing-pregnant-women-due-to-health-risks","name":"Urgent call for review into sentencing pregnant women due to health risks"},
    {"@type":"ListItem","position":15,"url":"https://www.theguardian.com/society/2022/mar/28/female-former-inmates-protest-uk-imprisonment-pregnant-women","name":"Mothers and babies join protest against UK imprisonment of pregnant women"},
    {"@type":"ListItem","position":16,"url":"https://www.theguardian.com/society/2022/feb/05/fa-and-premier-league-urged-to-help-tackle-gender-based-violence","name":"FA and Premier League urged to help tackle gender-based violence"},
    {"@type":"ListItem","position":17,"url":"https://www.theguardian.com/society/2024/jan/21/uk-prison-hmp-bronzefield-pregnant-women-aisha-cleary","name":"UK prison where baby died gives women rape alarms to call for help during labour"},
    {"@type":"ListItem","position":18,"url":"https://www.theguardian.com/technology/2019/mar/04/facebook-women-abuse-harassment-social-media-amnesty","name":"Facebook criticised after women complain of inaction over abuse"},
    {"@type":"ListItem","position":19,"url":"https://www.thesun.co.uk/news/16207265/pregnant-teen-dead-baby-prison-ignored-help/","name":"Pregnant teen, 18, found with dead baby in cell after being ignored for 12 HOURS"},
    {"@type":"ListItem","position":20,"url":"https://www.theguardian.com/society/2021/sep/25/prison-guards-but-not-mother-get-counselling-after-baby-dies-in-cell","name":"Prison guards, but not mother, get counselling after baby dies in cell"}
      ]
    }
  }
  </script>

  <main id="main-content">

    <!-- HERO -->
    <section class="pc-hero" aria-labelledby="press-heading">
      <div class="pc-hero-inner">
        <span class="pc-hero-label">Media Coverage</span>
        <h1 id="press-heading" class="pc-hero-title">Level Up<br/>in the Press</h1>
        <p class="pc-hero-intro">Level Up's feminist campaigns on reproductive justice, Black women's health, sexual violence in football, and domestic abuse have been covered by leading UK and international media since 2018.</p>
        <div class="pc-stats" role="list" aria-label="Coverage statistics">
          <div class="pc-stat" role="listitem"><span class="pc-stat-num">101</span><span class="pc-stat-label">media appearances</span></div>
          <div class="pc-stat" role="listitem"><span class="pc-stat-num">37</span><span class="pc-stat-label">outlets</span></div>
          <div class="pc-stat" role="listitem"><span class="pc-stat-num">5</span><span class="pc-stat-label">campaigns</span></div>
          <div class="pc-stat" role="listitem"><span class="pc-stat-num">2018&ndash;</span><span class="pc-stat-label">ongoing</span></div>
        </div>
      </div>
    </section>

    <!-- FILTERS -->
    <section class="pc-filters-wrap" aria-label="Filter press coverage by campaign">
      <div class="pc-filters-inner">
        <p class="pc-filters-label">Filter by campaign:</p>
        <div class="pc-filters" role="group" aria-label="Campaign filters">
          <button class="pc-filter active" data-filter="all" aria-pressed="true">All <span class="pc-filter-count">101</span></button>
          <button class="pc-filter" data-filter="pregnancy-in-prison" aria-pressed="false">Pregnancy in Prison <span class="pc-filter-count">50</span></button>
          <button class="pc-filter" data-filter="beauty" aria-pressed="false">#NoMoreLyes <span class="pc-filter-count">21</span></button>
          <button class="pc-filter" data-filter="other" aria-pressed="false">Other Campaigns <span class="pc-filter-count">12</span></button>
          <button class="pc-filter" data-filter="football" aria-pressed="false">Sexual Violence in Football <span class="pc-filter-count">11</span></button>
          <button class="pc-filter" data-filter="femicide" aria-pressed="false">Domestic Abuse in Media <span class="pc-filter-count">7</span></button>
        </div>
      </div>
    </section>

    <!-- PRESS GRID -->
    <section class="pc-grid-wrap" aria-live="polite" aria-atomic="false">
      <div class="pc-grid" id="press-grid" itemscope itemtype="https://schema.org/ItemList">

      <article class="pc-card" data-topic="pregnancy-in-prison" aria-label="Prisoners who gave birth in handcuffs sue Ministry of Justice" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="https://www.thetimes.com/article/85026ca4-a398-41a2-838e-4917f6595e2b" target="_blank" rel="noopener noreferrer" class="pc-card-link">
          <div class="pc-card-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/93390da7-476a-4b06-9ec7-2a7f45062bee.jpg')" role="img" aria-hidden="true"></div>
          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">The Times</span></span>
            <h3 class="pc-card-title" itemprop="headline">Prisoners who gave birth in handcuffs sue Ministry of Justice</h3>
            <p class="pc-card-desc">One of five women who went into labour while an inmate at HMP Bronzefield says she begged officers to remove her restraints in the hospital</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2025-05-30" itemprop="datePublished">May 30, 2025</time>
              <span class="pc-tag" style="--tag-color:#CCFF33">Pregnancy in Prison</span>
            </div>
          </div>
          <meta itemprop="url" content="https://www.thetimes.com/article/85026ca4-a398-41a2-838e-4917f6595e2b" />
        </a>
      </article>
      <article class="pc-card" data-topic="beauty" aria-label="Black women call for a ban on toxic hair products linked to cancer - Voice Online" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="https://www.voice-online.co.uk/news/uk-news/2025/05/27/black-women-call-for-a-ban-on-toxic-hair-products-linked-to-cancer/" target="_blank" rel="noopener noreferrer" class="pc-card-link">
          <div class="pc-card-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/rsz_gettyimages-1167753539_1.jpg')" role="img" aria-hidden="true"></div>
          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">Voice Online</span></span>
            <h3 class="pc-card-title" itemprop="headline">Black women call for a ban on toxic hair products linked to cancer - Voice Online</h3>
            <p class="pc-card-desc">Black women are calling for a ban on toxic hair ingredients - which have been linked to an increased risk of cancer and fibroids</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2025-05-28" itemprop="datePublished">May 28, 2025</time>
              <span class="pc-tag" style="--tag-color:#fb923c">#NoMoreLyes</span>
            </div>
          </div>
          <meta itemprop="url" content="https://www.voice-online.co.uk/news/uk-news/2025/05/27/black-women-call-for-a-ban-on-toxic-hair-products-linked-to-cancer/" />
        </a>
      </article>
      <article class="pc-card" data-topic="pregnancy-in-prison" aria-label="Sentencing of pregnant women: a 21st century approach" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="https://www.counselmagazine.co.uk/articles/sentencing-of-pregnant-women-a-21st-century-approach" target="_blank" rel="noopener noreferrer" class="pc-card-link">
          <div class="pc-card-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/209602.jpeg')" role="img" aria-hidden="true"></div>
          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">Counsel Magazine</span></span>
            <h3 class="pc-card-title" itemprop="headline">Sentencing of pregnant women: a 21st century approach</h3>
            <p class="pc-card-desc">Maya Sikand KC and Janey Starling, co-authors of a new toolkit, Representing pregnant women and mothers in the criminal justice system, believe that advocates can play a critical role in ensuring that sentencers get it right</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2025-03-15" itemprop="datePublished">March 15, 2025</time>
              <span class="pc-tag" style="--tag-color:#CCFF33">Pregnancy in Prison</span>
            </div>
          </div>
          <meta itemprop="url" content="https://www.counselmagazine.co.uk/articles/sentencing-of-pregnant-women-a-21st-century-approach" />
        </a>
      </article>
      <article class="pc-card" data-topic="pregnancy-in-prison" aria-label="Pregnant in prison: 'When I thought my baby had died nobody seemed to care'" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="https://metro.co.uk/2025/02/22/pregnant-prison-i-thought-baby-died-treated-like-inconvenience-22578382/" target="_blank" rel="noopener noreferrer" class="pc-card-link">
          <div class="pc-card-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/SEI_240415609-b585_1740213612.jpg')" role="img" aria-hidden="true"></div>
          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">Metro</span></span>
            <h3 class="pc-card-title" itemprop="headline">Pregnant in prison: 'When I thought my baby had died nobody seemed to care'</h3>
            <p class="pc-card-desc">Pregnant women in prison are seven times more likely to suffer stillbirth and twice as likely to give birth prematurely.</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2025-02-22" itemprop="datePublished">February 22, 2025</time>
              <span class="pc-tag" style="--tag-color:#CCFF33">Pregnancy in Prison</span>
            </div>
          </div>
          <meta itemprop="url" content="https://metro.co.uk/2025/02/22/pregnant-prison-i-thought-baby-died-treated-like-inconvenience-22578382/" />
        </a>
      </article>
      <article class="pc-card" data-topic="other" aria-label="A mother’s fight for justice after baby dies in prison" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="https://www.channel4.com/news/a-mothers-fight-for-justice-after-baby-dies-in-prison" target="_blank" rel="noopener noreferrer" class="pc-card-link">
          <div class="pc-card-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/ZH0hNo8W_image-1-1920x1080-1.png')" role="img" aria-hidden="true"></div>
          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">Channel 4 News</span></span>
            <h3 class="pc-card-title" itemprop="headline">A mother’s fight for justice after baby dies in prison</h3>
            <p class="pc-card-desc">Baby Aisha Cleary died in a prison cell after her then teenage mother, Rianna, was left to give birth alone in 2019. Earlier this year, a coroner ruled that multiple systemic failures led to her death.</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2023-11-14" itemprop="datePublished">November 14, 2023</time>
              <span class="pc-tag" style="--tag-color:#a78bfa">Other Campaigns</span>
            </div>
          </div>
          <meta itemprop="url" content="https://www.channel4.com/news/a-mothers-fight-for-justice-after-baby-dies-in-prison" />
        </a>
      </article>
      <article class="pc-card" data-topic="pregnancy-in-prison" aria-label="Alarming data reveals high diabetes risk for pregnant women in English jails" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="https://www.theguardian.com/society/2025/feb/23/alarming-data-reveals-high-diabetes-risk-for-pregnant-women-in-english-jails" target="_blank" rel="noopener noreferrer" class="pc-card-link">
          <div class="pc-card-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/5184.jpg')" role="img" aria-hidden="true"></div>
          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">The Guardian</span></span>
            <h3 class="pc-card-title" itemprop="headline">Alarming data reveals high diabetes risk for pregnant women in English jails</h3>
            <p class="pc-card-desc">Freedom of information requests show that female prisoners are three times more likely to suffer gestational diabetes</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2025-02-23" itemprop="datePublished">February 23, 2025</time>
              <span class="pc-tag" style="--tag-color:#CCFF33">Pregnancy in Prison</span>
            </div>
          </div>
          <meta itemprop="url" content="https://www.theguardian.com/society/2025/feb/23/alarming-data-reveals-high-diabetes-risk-for-pregnant-women-in-english-jails" />
        </a>
      </article>
      <article class="pc-card" data-topic="pregnancy-in-prison" aria-label="Prisoners forced to give birth handcuffed to male officers" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="https://www.thetimes.com/uk/crime/article/pregnant-women-prison-birth-handcuffed-male-officers-5f0698ks8" target="_blank" rel="noopener noreferrer" class="pc-card-link">
          <div class="pc-card-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/47d44d6d-eeb0-4147-b6a3-9e7f693d559e.jpg')" role="img" aria-hidden="true"></div>
          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">The Times</span></span>
            <h3 class="pc-card-title" itemprop="headline">Prisoners forced to give birth handcuffed to male officers</h3>
            <p class="pc-card-desc">At least two female prisoners have come forward over incidents that occurred at HMP Bronzefield in Surrey between 2021 and 2023</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2025-02-21" itemprop="datePublished">February 21, 2025</time>
              <span class="pc-tag" style="--tag-color:#CCFF33">Pregnancy in Prison</span>
            </div>
          </div>
          <meta itemprop="url" content="https://www.thetimes.com/uk/crime/article/pregnant-women-prison-birth-handcuffed-male-officers-5f0698ks8" />
        </a>
      </article>
      <article class="pc-card" data-topic="other" aria-label="‘Prison will never be a safe place to be pregnant’ – campaigner" itemscope itemtype="https://schema.org/NewsArticle">
        <a href="https://www.channel4.com/news/prison-will-never-be-a-safe-place-to-be-pregnant-campaigner" target="_blank" rel="noopener noreferrer" class="pc-card-link">
          <div class="pc-card-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/story-4-thumb-1-1920x1080-1.png')" role="img" aria-hidden="true"></div>
          <div class="pc-card-body">
            <span class="pc-outlet" itemprop="publisher" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">Channel 4 News</span></span>
            <h3 class="pc-card-title" itemprop="headline">‘Prison will never be a safe place to be pregnant’ – campaigner</h3>
            <p class="pc-card-desc">We spoke to Janey Starling, from the feminist campaign group Level Up, and former prison governor Pia Sinha, who now heads the Prison Reform Trust.</p>
            <div class="pc-card-footer">
              <time class="pc-date" datetime="2025-02-19" itemprop="datePublished">February 19, 2025</time>
              <span class="pc-tag" style="--tag-color:#a78bfa">Other Campaigns</span>
            </div>
          </div>
          <meta itemprop="url" content="https://www.channel4.com/news/prison-will-never-be-a-safe-place-to-be-pregnant-campaigner" />
        </a>
      </article>
