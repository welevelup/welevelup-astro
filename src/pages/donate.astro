---
/**
 * Custom donate page that REPLACES the cloned WordPress /donate.
 *
 * Astro prefers static routes over the [...slug] catch-all, so simply having
 * this file at src/pages/donate.astro takes precedence — no need to touch
 * src/_clone/donate/.
 *
 * Visually we re-use the head (Elementor CSS, fonts, tracking) from the
 * cloned home page so the page sits inside the existing brand and renders
 * with the same chrome (nav, footer) as the rest of the site.
 */
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { extract } from '../lib/extractHtml';
import homeRaw from '../_clone/index.html?raw';

const { headInner, bodyClass } = extract(homeRaw);
---
<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />
  <main class="lu-donate">
    <section class="lu-donate__hero">
      <h1>Support Level Up</h1>
      <p>
        Level Up runs on small, regular donations from people like you. Your
        contribution funds feminist campaigns for gender justice in the UK.
      </p>
    </section>

    <form class="lu-donate__form" id="donate-form" novalidate>
      <fieldset class="lu-donate__field lu-donate__field--type">
        <legend>How would you like to give?</legend>
        <label>
          <input type="radio" name="frequency" value="monthly" checked />
          <span>Monthly</span>
        </label>
        <label>
          <input type="radio" name="frequency" value="one-time" />
          <span>One-time</span>
        </label>
      </fieldset>

      <fieldset class="lu-donate__field lu-donate__field--amount">
        <legend>Choose an amount (GBP)</legend>
        <div class="lu-donate__amounts">
          <label><input type="radio" name="preset" value="5" /><span>£5</span></label>
          <label><input type="radio" name="preset" value="10" checked /><span>£10</span></label>
          <label><input type="radio" name="preset" value="15" /><span>£15</span></label>
          <label><input type="radio" name="preset" value="custom" /><span>Other</span></label>
        </div>
        <label class="lu-donate__custom" hidden>
          <span>Custom amount</span>
          <input type="number" name="customAmount" min="1" step="1" placeholder="£" />
        </label>
      </fieldset>

      <fieldset class="lu-donate__field lu-donate__field--details">
        <legend>Your details</legend>
        <label>
          <span>Full name <em>(required for monthly)</em></span>
          <input type="text" name="donorName" autocomplete="name" />
        </label>
        <label>
          <span>Email <em>(required for monthly)</em></span>
          <input type="email" name="donorEmail" autocomplete="email" />
        </label>
      </fieldset>

      <p class="lu-donate__error" id="donate-error" role="alert" hidden></p>

      <button type="submit" class="lu-donate__submit">
        Continue to secure payment →
      </button>

      <p class="lu-donate__legal">
        Payments are processed by Mollie. We don't store your card details. You
        can cancel a monthly donation at any time by emailing
        <a href="mailto:hello@welevelup.org">hello@welevelup.org</a>.
      </p>
    </form>
  </main>
  <Footer />

  <style is:global>
    .lu-donate {
      max-width: 560px;
      margin: 0 auto;
      padding: 64px 24px 96px;
      font-family: 'DM Sans', system-ui, sans-serif;
      color: #0d0a3e;
    }
    .lu-donate__logo {
      display: block;
      margin-bottom: 32px;
    }
    .lu-donate__logo img {
      height: 46px;
      width: auto;
    }
    .lu-donate__hero h1 {
      font-size: 48px;
      line-height: 1.05;
      margin: 0 0 16px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #0d0a3e !important;
    }
    .lu-donate__hero p {
      font-size: 18px;
      line-height: 1.5;
      margin: 0 0 40px;
    }
    .lu-donate__form fieldset {
      border: none;
      padding: 0;
      margin: 0 0 32px;
    }
    .lu-donate__form legend {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      margin-bottom: 12px;
      color: #0d0a3e;
    }
    .lu-donate__field--type {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .lu-donate__field--type label {
      flex: 1;
      min-width: 140px;
      cursor: pointer;
    }
    .lu-donate__field--type input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
    .lu-donate__field--type span,
    .lu-donate__amounts span {
      display: block;
      padding: 14px 20px;
      border: 2px solid #0d0a3e;
      text-align: center;
      font-weight: 600;
      transition: all 0.15s;
      background: transparent;
    }
    .lu-donate__field--type input:checked + span,
    .lu-donate__amounts input:checked + span {
      background: #cbff32;
      color: #0d0a3e;
    }
    .lu-donate__amounts {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }
    .lu-donate__amounts label {
      cursor: pointer;
    }
    .lu-donate__amounts input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
    .lu-donate__custom {
      display: block;
      margin-top: 16px;
    }
    .lu-donate__custom span {
      display: block;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .lu-donate__custom input {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid #0d0a3e;
      font-size: 16px;
      font-family: inherit;
    }
    .lu-donate__field--details label {
      display: block;
      margin-bottom: 16px;
    }
    .lu-donate__field--details span {
      display: block;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .lu-donate__field--details em {
      text-transform: none;
      letter-spacing: 0;
      font-weight: 400;
      font-style: normal;
      color: #6b6b6b;
    }
    .lu-donate__field--details input {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid #0d0a3e;
      font-size: 16px;
      font-family: inherit;
    }
    .lu-donate__error {
      background: #ffe5e5;
      border-left: 4px solid #d40000;
      padding: 12px 16px;
      font-size: 14px;
      margin: 0 0 16px;
      color: #8a0000;
    }
    .lu-donate__submit {
      display: block;
      width: 100%;
      padding: 18px 24px;
      background: #0d0a3e;
      color: #cbff32;
      border: none;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 0.02em;
      transition: background 0.15s;
      font-family: inherit;
    }
    .lu-donate__submit:hover {
      background: #1a1660;
    }
    .lu-donate__submit:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .lu-donate__legal {
      font-size: 13px;
      color: #6b6b6b;
      margin: 24px 0 0;
      text-align: center;
      line-height: 1.5;
    }
    .lu-donate__legal a {
      color: #0d0a3e;
    }
  </style>

  <script>
    const form = document.getElementById('donate-form') as HTMLFormElement;
    const errorEl = document.getElementById('donate-error') as HTMLElement;
    const customWrap = form.querySelector('.lu-donate__custom') as HTMLElement;
    const customInput = form.querySelector('input[name="customAmount"]') as HTMLInputElement;
    const presetInputs = form.querySelectorAll<HTMLInputElement>('input[name="preset"]');

    function showError(msg: string) {
      errorEl.textContent = msg;
      errorEl.hidden = false;
    }
    function clearError() {
      errorEl.hidden = true;
      errorEl.textContent = '';
    }

    presetInputs.forEach((el) =>
      el.addEventListener('change', () => {
        if (el.value === 'custom' && el.checked) {
          customWrap.hidden = false;
          customInput.focus();
        } else {
          customWrap.hidden = true;
        }
      })
    );

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearError();

      const formData = new FormData(form);
      const frequency = formData.get('frequency') as string;
      const preset = formData.get('preset') as string;
      const custom = formData.get('customAmount') as string;
      const donorName = (formData.get('donorName') as string).trim();
      const donorEmail = (formData.get('donorEmail') as string).trim();

      const amount = preset === 'custom' ? custom : preset;
      if (!amount || parseFloat(amount) < 1) {
        showError('Please choose or enter an amount of at least £1.');
        return;
      }

      const recurring = frequency === 'monthly';
      if (recurring && (!donorName || !donorEmail)) {
        showError('Name and email are required for monthly donations.');
        return;
      }

      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submit.disabled = true;
      submit.textContent = 'Connecting to Mollie…';

      try {
        const res = await fetch('/api/create-donation', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ amount, recurring, donorName, donorEmail }),
        });
        const data = await res.json();
        if (!res.ok || !data.checkoutUrl) {
          throw new Error(data.error || 'Could not start payment');
        }
        window.location.href = data.checkoutUrl;
      } catch (err) {
        showError(err instanceof Error ? err.message : 'Unknown error');
        submit.disabled = false;
        submit.textContent = 'Continue to secure payment →';
      }
    });
  </script>
</Layout>
