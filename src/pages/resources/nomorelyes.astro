<script>
  (function () {
    const pills = document.querySelectorAll<HTMLButtonElement>('.nr-pill');
    const items = document.querySelectorAll<HTMLLIElement>('.nr-resource-item');
    function setFilter(tag: string) {
      pills.forEach((p) => {
        const active = p.dataset.filter === tag;
        p.classList.toggle('nr-pill--active', active);
        p.setAttribute('aria-pressed', String(active));
      });
      items.forEach((item) => {
        const tags = (item.dataset.tags || '').split(' ');
        tags.includes(tag) || tag === 'all' ? item.removeAttribute('hidden') : item.setAttribute('hidden', '');
      });
    }
    pills.forEach((p) => p.addEventListener('click', () => setFilter(p.dataset.filter ?? 'all')));
  })();
</script>
