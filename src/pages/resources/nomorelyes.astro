---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { extract } from '../../lib/extractHtml';
import homeRaw from '../../_clone/index.html?raw';
const { headInner, bodyClass } = extract(homeRaw);
---

<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />

  <!-- ═══════════════════════════════════════════════════════════
       HERO — cream background, editorial oversized type
  ════════════════════════════════════════════════════════════ -->
  <section class="nr-hero" aria-labelledby="nr-hero-heading">
    <div class="nr-hero-inner">
      <span class="nr-eyebrow">#NoMoreLyes</span>
      <h1 id="nr-hero-heading" class="nr-hero-title">
        Relaxer<br/>Info Kit
      </h1>
      <p class="nr-hero-subtitle">
        A growing body of research links chemical hair relaxers to serious health
        conditions. These are the studies, the coverage, and the organisations
        leading the conversation.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FILTER TAG ROW
  ════════════════════════════════════════════════════════════ -->
  <section class="nr-filters" aria-label="Filter resources by category">
    <div class="nr-filters-inner">
      <button class="nr-pill nr-pill--active" data-filter="all" aria-pressed="true">All</button>
      <button class="nr-pill" data-filter="academic" aria-pressed="false">Academic</button>
      <button class="nr-pill" data-filter="media" aria-pressed="false">Media</button>
      <button class="nr-pill" data-filter="parliament" aria-pressed="false">Parliament</button>
      <button class="nr-pill" data-filter="organisations" aria-pressed="false">Organisations</button>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       TWO-COLUMN BODY — sticky sidebar + resource list
  ════════════════════════════════════════════════════════════ -->
  <section class="nr-body">
    <div class="nr-body-inner">

      <!-- LEFT SIDEBAR -->
      <aside class="nr-sidebar" aria-label="Campaign info and actions">
        <p class="nr-sidebar-campaign">&#35;NoMoreLyes</p>
        <p class="nr-sidebar-desc">
          Level Up launched #NoMoreLyes in 2021 targeting L'Oréal, the world's
          largest manufacturer of hair relaxers, over the links between their
          products and serious illness in Black women.
        </p>

        <div class="nr-sidebar-stats">
          <div class="nr-stat">
            <span class="nr-stat-num">9+</span>
            <span class="nr-stat-label">Studies</span>
          </div>
          <div class="nr-stat">
            <span class="nr-stat-num">2025</span>
            <span class="nr-stat-label">Parliamentary submission</span>
          </div>
        </div>

        <hr class="nr-divider" />

        <nav class="nr-sidebar-actions" aria-label="Campaign actions">
          <a
            href="https://levelup.yourmovement.org/p/no-more-lyes"
            target="_blank"
            rel="noopener"
            class="nr-action-link"
          >Sign the petition →</a>
          <a
            href="https://levelup.movement-action.org/p/share-your-hair-story"
            target="_blank"
            rel="noopener"
            class="nr-action-link"
          >Share your hair story →</a>
          <a
            href="https://levelup.yourmovement.org/p/no-more-lyes"
            target="_blank"
            rel="noopener"
            class="nr-action-link"
          >Open letter to L'Oréal →</a>
        </nav>
      </aside>

      <!-- RIGHT CONTENT -->
      <div class="nr-content">

        <!-- Featured document -->
        <article class="nr-featured" aria-label="Featured resource">
          <span class="nr-featured-badge">KEY DOCUMENT</span>
          <h2 class="nr-featured-title">
            Level Up's Parliamentary Submission 2025
          </h2>
          <p class="nr-featured-desc">
            Submitted to the UK Parliament's inquiry — the most comprehensive
            public record of Level Up's evidence on hair relaxer harm.
          </p>
          <a
            href="https://committees.parliament.uk/writtenevidence/160638/pdf/"
            target="_blank"
            rel="noopener"
            class="nr-featured-btn"
          >Download PDF →</a>
        </article>

        <!-- Numbered resource list -->
        <ol class="nr-list" aria-label="All campaign resources">

          <li class="nr-resource-item" data-tag="academic">
            <span class="nr-item-num" aria-hidden="true">01</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">Use of Straighteners and Incident Uterine Cancer</h3>
              <p class="nr-item-meta">Oxford / NIH · 2022</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge">Academic</span>
              <a
                href="https://doi.org/10.1093/jnci/djac165"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Read Use of Straighteners and Incident Uterine Cancer"
              >↗</a>
            </div>
          </li>

          <li class="nr-resource-item" data-tag="academic">
            <span class="nr-item-num" aria-hidden="true">02</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">Hair Product Use and Breast Cancer Incidence</h3>
              <p class="nr-item-meta">Academic · 2021</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge">Academic</span>
              <a
                href="https://doi.org/10.1093/carcin/bgab041"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Read Hair Product Use and Breast Cancer Incidence"
              >↗</a>
            </div>
          </li>

          <li class="nr-resource-item" data-tag="academic">
            <span class="nr-item-num" aria-hidden="true">03</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">Hair-Straightening Products and Acute Kidney Failure Risk</h3>
              <p class="nr-item-meta">Medscape · 2024</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge">Academic</span>
              <a
                href="https://medscape.com"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Read Hair-Straightening Products and Acute Kidney Failure Risk"
              >↗</a>
            </div>
          </li>

          <li class="nr-resource-item" data-tag="parliament">
            <span class="nr-item-num" aria-hidden="true">04</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">Level Up's Parliamentary Submission</h3>
              <p class="nr-item-meta">Parliament · Dec 2025</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge nr-type-badge--parliament">Parliament</span>
              <a
                href="https://committees.parliament.uk/writtenevidence/160638/pdf/"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Read Level Up's Parliamentary Submission"
              >↗</a>
            </div>
          </li>

          <li class="nr-resource-item" data-tag="media">
            <span class="nr-item-num" aria-hidden="true">05</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">While Black Women Abandon Relaxers, Sales Climb in African Countries</h3>
              <p class="nr-item-meta">The Examination · April 2024</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge nr-type-badge--media">Media</span>
              <a
                href="https://theexamination.org"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Read While Black Women Abandon Relaxers, Sales Climb in African Countries"
              >↗</a>
            </div>
          </li>

          <li class="nr-resource-item" data-tag="media">
            <span class="nr-item-num" aria-hidden="true">06</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">Majority of Black British Women Suffer Side Effects</h3>
              <p class="nr-item-meta">The Independent · May 2023</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge nr-type-badge--media">Media</span>
              <a
                href="https://independent.co.uk"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Read Majority of Black British Women Suffer Side Effects"
              >↗</a>
            </div>
          </li>

          <li class="nr-resource-item" data-tag="organisations">
            <span class="nr-item-num" aria-hidden="true">07</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">Treasure Tress — Natural hair product discovery platform</h3>
              <p class="nr-item-meta">Organisation</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge nr-type-badge--org">Organisation</span>
              <a
                href="https://treasuretress.com"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Visit Treasure Tress"
              >↗</a>
            </div>
          </li>

          <li class="nr-resource-item" data-tag="organisations">
            <span class="nr-item-num" aria-hidden="true">08</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">Project Embrace — Afro-textured hair representation</h3>
              <p class="nr-item-meta">Organisation</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge nr-type-badge--org">Organisation</span>
              <a
                href="https://projectembrace.org"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Visit Project Embrace"
              >↗</a>
            </div>
          </li>

          <li class="nr-resource-item" data-tag="organisations">
            <span class="nr-item-num" aria-hidden="true">09</span>
            <div class="nr-item-body">
              <h3 class="nr-item-title">Curlture UK — Culture and curls</h3>
              <p class="nr-item-meta">Organisation</p>
            </div>
            <div class="nr-item-end">
              <span class="nr-type-badge nr-type-badge--org">Organisation</span>
              <a
                href="https://curlture.co.uk"
                target="_blank"
                rel="noopener"
                class="nr-item-link"
                aria-label="Visit Curlture UK"
              >↗</a>
            </div>
          </li>

        </ol>
      </div><!-- /nr-content -->
    </div><!-- /nr-body-inner -->
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       NAVY CTA
  ════════════════════════════════════════════════════════════ -->
  <section class="nr-cta" aria-labelledby="nr-cta-heading">
    <div class="nr-cta-inner">
      <h2 id="nr-cta-heading" class="nr-cta-title">
        Join the Level Up community
      </h2>
      <p class="nr-cta-body">
        Receive campaign updates, research summaries, and actions you can
        take — straight to your inbox.
      </p>
      <a
        href="https://levelup.yourmovement.org/p/join-us"
        target="_blank"
        rel="noopener"
        class="nr-cta-btn"
      >JOIN US →</a>
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  /* ── Font scope ──────────────────────────────────────────── */
  .nr-hero,
  .nr-filters,
  .nr-body,
  .nr-cta {
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  /* ════════════════════════════════════════════════════════════
     HERO
  ═══════════════════════════════════════════════════════════ */
  .nr-hero {
    background: #EEEBD3;
    padding: 100px 24px 80px;
  }

  .nr-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .nr-eyebrow {
    display: inline-block;
    font: 700 11px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #A89CED;
    margin-bottom: 24px;
  }

  .nr-hero-title {
    font: 900 clamp(56px, 11vw, 120px)/0.88 'DM Sans', sans-serif;
    color: #0C0A3E;
    letter-spacing: -0.05em;
    margin: 0 0 32px;
  }

  .nr-hero-subtitle {
    font: 400 18px/1.65 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.6);
    max-width: 560px;
    margin: 0;
  }

  /* ════════════════════════════════════════════════════════════
     FILTER PILLS
  ═══════════════════════════════════════════════════════════ */
  .nr-filters {
    background: #EEEBD3;
    border-top: 1px solid rgba(12, 10, 62, 0.1);
    padding: 20px 24px;
  }

  .nr-filters-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .nr-pill {
    font: 700 12px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #0C0A3E;
    background: transparent;
    border: 1.5px solid #0C0A3E;
    border-radius: 100px;
    padding: 9px 18px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .nr-pill:hover {
    background: rgba(12, 10, 62, 0.07);
  }

  .nr-pill--active {
    background: #0C0A3E;
    color: #CCFF33;
    border-color: #0C0A3E;
  }

  .nr-pill--active:hover {
    background: #1a185a;
  }

  /* ════════════════════════════════════════════════════════════
     TWO-COLUMN BODY
  ═══════════════════════════════════════════════════════════ */
  .nr-body {
    background: #EEEBD3;
    border-top: 1px solid rgba(12, 10, 62, 0.08);
    padding: 72px 24px 96px;
  }

  .nr-body-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: start;
  }

  /* ── Sidebar ─────────────────────────────────────────────── */
  .nr-sidebar {
    position: sticky;
    top: 100px;
  }

  .nr-sidebar-campaign {
    font: 700 10px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #0C0A3E;
    margin: 0 0 16px;
  }

  .nr-sidebar-desc {
    font: 400 14px/1.65 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.65);
    margin: 0 0 28px;
  }

  .nr-sidebar-stats {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 28px;
  }

  .nr-stat-num {
    display: block;
    font: 800 32px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    letter-spacing: -0.03em;
  }

  .nr-stat-label {
    display: block;
    font: 400 12px/1.4 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.55);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .nr-divider {
    border: none;
    border-top: 1px solid rgba(12, 10, 62, 0.14);
    margin: 0 0 24px;
  }

  .nr-sidebar-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nr-action-link {
    display: block;
    font: 700 13px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 14px 0;
    border-bottom: 1px solid rgba(12, 10, 62, 0.1);
    transition: color 0.15s, padding-left 0.15s;
  }

  .nr-action-link:hover {
    color: #A89CED;
    padding-left: 6px;
  }

  /* ── Featured card ───────────────────────────────────────── */
  .nr-featured {
    background: #0C0A3E;
    padding: 40px 44px;
    margin-bottom: 48px;
  }

  .nr-featured-badge {
    display: inline-block;
    font: 700 10px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #0C0A3E;
    background: #A89CED;
    padding: 5px 10px;
    margin-bottom: 20px;
  }

  .nr-featured-title {
    font: 800 clamp(22px, 3vw, 30px)/1.1 'DM Sans', sans-serif;
    color: #EEEBD3;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  .nr-featured-desc {
    font: 400 15px/1.65 'DM Sans', sans-serif;
    color: rgba(238, 235, 211, 0.65);
    margin: 0 0 28px;
    max-width: 580px;
  }

  .nr-featured-btn {
    display: inline-block;
    font: 800 13px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: #CCFF33;
    color: #0C0A3E;
    text-decoration: none;
    padding: 14px 28px;
    transition: background 0.15s;
  }

  .nr-featured-btn:hover {
    background: #EEEBD3;
  }

  /* ── Resource list ───────────────────────────────────────── */
  .nr-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nr-resource-item {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    gap: 20px;
    align-items: center;
    padding: 22px 0;
    border-bottom: 1px solid rgba(12, 10, 62, 0.1);
    transition: background 0.15s, margin 0.15s, padding 0.15s;
  }

  .nr-resource-item:first-child {
    border-top: 1px solid rgba(12, 10, 62, 0.1);
  }

  .nr-resource-item:hover {
    background: rgba(12, 10, 62, 0.03);
    margin: 0 -12px;
    padding-left: 12px;
    padding-right: 12px;
  }

  .nr-resource-item[hidden] {
    display: none;
  }

  .nr-item-num {
    font: 800 13px/1 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: 0.04em;
    align-self: center;
  }

  .nr-item-title {
    font: 700 15px/1.3 'DM Sans', sans-serif;
    color: #0C0A3E;
    margin: 0 0 4px;
  }

  .nr-item-meta {
    font: 400 12px/1 'DM Sans', sans-serif;
    color: rgba(12, 10, 62, 0.45);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .nr-item-end {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nr-type-badge {
    font: 700 10px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0C0A3E;
    background: rgba(12, 10, 62, 0.08);
    padding: 5px 10px;
    white-space: nowrap;
  }

  .nr-type-badge--parliament {
    background: rgba(168, 156, 237, 0.25);
    color: #0C0A3E;
  }

  .nr-type-badge--media {
    background: rgba(204, 255, 51, 0.35);
    color: #0C0A3E;
  }

  .nr-type-badge--org {
    background: rgba(12, 10, 62, 0.06);
    color: rgba(12, 10, 62, 0.7);
  }

  .nr-item-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font: 700 16px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    text-decoration: none;
    border: 1.5px solid rgba(12, 10, 62, 0.2);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  .nr-item-link:hover {
    background: #0C0A3E;
    color: #CCFF33;
    border-color: #0C0A3E;
  }

  /* ════════════════════════════════════════════════════════════
     NAVY CTA
  ═══════════════════════════════════════════════════════════ */
  .nr-cta {
    background: #0C0A3E;
    padding: 96px 24px;
    text-align: center;
  }

  .nr-cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .nr-cta-title {
    font: 900 clamp(32px, 5vw, 52px)/1.05 'DM Sans', sans-serif;
    color: #EEEBD3;
    letter-spacing: -0.04em;
    margin: 0 0 20px;
  }

  .nr-cta-body {
    font: 400 17px/1.65 'DM Sans', sans-serif;
    color: rgba(238, 235, 211, 0.65);
    margin: 0 0 36px;
  }

  .nr-cta-btn {
    display: inline-block;
    font: 800 13px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: #CCFF33;
    color: #0C0A3E;
    text-decoration: none;
    padding: 18px 40px;
    transition: background 0.15s;
  }

  .nr-cta-btn:hover {
    background: #EEEBD3;
  }

  /* ════════════════════════════════════════════════════════════
     RESPONSIVE — sidebar stacks at 900px, list reflows at 640px
  ═══════════════════════════════════════════════════════════ */
  @media (max-width: 900px) {
    .nr-body-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .nr-sidebar {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      align-items: start;
    }

    .nr-sidebar-campaign,
    .nr-sidebar-desc {
      grid-column: 1 / -1;
    }

    .nr-sidebar-stats {
      flex-direction: row;
      gap: 32px;
    }

    .nr-divider {
      grid-column: 1 / -1;
      margin: 0;
    }

    .nr-sidebar-actions {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .nr-hero {
      padding: 72px 20px 56px;
    }

    .nr-featured {
      padding: 28px 24px;
    }

    .nr-resource-item {
      grid-template-columns: 32px 1fr;
      grid-template-rows: auto auto;
    }

    .nr-item-end {
      grid-column: 2;
      margin-top: 8px;
    }

    .nr-resource-item:hover {
      margin: 0 -8px;
      padding-left: 8px;
      padding-right: 8px;
    }

    .nr-sidebar {
      grid-template-columns: 1fr;
    }

    .nr-cta {
      padding: 64px 20px;
    }
  }
</style>

<script>
  (function () {
    const pills = document.querySelectorAll<HTMLButtonElement>('.nr-pill');
    const items = document.querySelectorAll<HTMLLIElement>('.nr-resource-item');

    function setFilter(tag: string) {
      pills.forEach((pill) => {
        const isActive = pill.dataset.filter === tag;
        pill.classList.toggle('nr-pill--active', isActive);
        pill.setAttribute('aria-pressed', String(isActive));
      });

      items.forEach((item) => {
        const matches = tag === 'all' || item.dataset.tag === tag;
        if (matches) {
          item.removeAttribute('hidden');
        } else {
          item.setAttribute('hidden', '');
        }
      });
    }

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        setFilter(pill.dataset.filter ?? 'all');
      });
    });
  })();
</script>
