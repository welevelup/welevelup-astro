---
const socialLinks = [
  { label: 'Facebook', href: 'https://www.facebook.com/levelupaction', icon: 'facebook' },
  { label: 'Twitter / X', href: 'https://x.com/we_level_up', icon: 'twitter' },
  { label: 'Instagram', href: 'https://www.instagram.com/levelup_uk/', icon: 'instagram' },
];
---

<footer class="footer">
  <div class="footer__inner">

    <!-- Logo + Social column -->
    <div class="footer__brand">
      <img src="/images/footer-logo.webp" alt="Level Up" width="180" class="footer__logo" />
      <div class="footer__social">
        {socialLinks.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class="footer__social-link">
            {s.icon === 'facebook' && (
              <svg viewBox="0 0 320 512" width="25" height="25" fill="currentColor" aria-hidden="true">
                <path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"/>
              </svg>
            )}
            {s.icon === 'twitter' && (
              <svg viewBox="0 0 512 512" width="25" height="25" fill="currentColor" aria-hidden="true">
                <path d="M459.37 151.72c.33 4.55.33 9.1.33 13.65 0 138.72-105.58 298.56-298.56 298.56-59.45 0-114.68-17.22-161.14-47.11 8.45.97 16.57 1.3 25.34 1.3 49.06 0 94.21-16.57 130.27-44.83-46.13-.98-84.79-31.19-98.11-72.77 6.5.97 13 1.62 19.82 1.62 9.42 0 18.84-1.3 27.61-3.57-48.08-9.75-84.14-51.98-84.14-102.99v-1.3c13.97 7.8 30.21 12.67 47.43 13.32-28.26-18.84-46.78-51-46.78-87.39 0-19.49 5.2-37.36 14.29-52.95 51.66 63.68 129.3 105.26 216.37 109.81-1.62-7.8-2.6-15.92-2.6-24.04 0-57.83 46.78-104.93 104.93-104.93 30.21 0 57.5 12.67 76.67 33.14 23.72-4.55 46.46-13.32 66.6-25.34-7.8 24.37-24.37 44.83-46.13 57.83 21.12-2.27 41.58-8.12 60.43-16.24-14.29 20.79-32.16 39.31-52.63 54.25z"/>
              </svg>
            )}
            {s.icon === 'instagram' && (
              <svg viewBox="0 0 448 512" width="25" height="25" fill="currentColor" aria-hidden="true">
                <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- Contact column -->
    <div class="footer__contact">
      <p>
        <a href="mailto:hello@welevelup.org">hello@welevelup.org</a><br />
        New Derwent House<br />
        69 – 73 Theobalds Road<br />
        London<br />
        WC1X 8TA
      </p>
    </div>

    <!-- Copyright column -->
    <div class="footer__legal">
      <p>&copy; 2018–2025 Level Up. All Rights Reserved.</p>
      <p>
        Except where otherwise noted, content on this site is licensed under a
        <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener">
          CC BY-NC-ND 4.0 International License
        </a>.
      </p>
      <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener">
        <img src="/images/footer-logo-1.webp" alt="Creative Commons BY-NC-ND 4.0" class="footer__cc-badge" />
      </a>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: #EDEBD2;
    padding: 6rem 1.2rem;
  }

  .footer__inner {
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: flex-start;
  }

  /* Logo column */
  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 0 0 84%;
    max-width: 84%;
  }

  .footer__logo {
    width: 180px;
    height: auto;
    display: block;
    margin-bottom: 1rem;
  }

  .footer__social {
    display: flex;
    flex-direction: row;
    gap: 5px;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(237, 235, 210, 0);
    border: 1px solid #DEDCC6;
    border-radius: 50%;
    color: #23214D;
    transition: background-color 0.2s, border-color 0.2s;
    text-decoration: none;
  }

  .footer__social-link:hover {
    background-color: rgba(35, 33, 77, 0.08);
    border-color: #23214D;
  }

  /* Contact column */
  .footer__contact {
    flex: 0 0 74%;
    max-width: 74%;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #0D0A3E;
    line-height: 1.7;
  }

  .footer__contact a {
    color: #0D0A3E;
    text-decoration: none;
  }

  .footer__contact a:hover {
    text-decoration: underline;
  }

  /* Copyright column */
  .footer__legal {
    flex: 0 0 100%;
    max-width: 100%;
    padding-right: 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: #0A0A0A;
    line-height: 1.6;
  }

  .footer__legal p {
    margin-bottom: 0.5rem;
  }

  .footer__legal a {
    color: #A89CED;
    text-decoration: none;
  }

  .footer__legal a:hover {
    color: #A89CED;
    text-decoration: underline;
  }

  .footer__cc-badge {
    display: block;
    margin-top: 0.5rem;
    height: auto;
  }

  /* Tablet (max 1024px): stack columns */
  @media (max-width: 1024px) {
    .footer__inner {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    .footer__brand {
      flex: none;
      max-width: 100%;
      width: 100%;
      align-items: center;
    }

    .footer__contact {
      flex: none;
      max-width: 75%;
      width: 75%;
      text-align: center;
    }

    .footer__legal {
      flex: none;
      max-width: 75%;
      width: 75%;
      text-align: center;
      padding-right: 0;
    }

    .footer__cc-badge {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* Mobile (max 767px): column layout, tighter padding */
  @media (max-width: 767px) {
    .footer {
      padding: 4rem 1.2rem;
    }

    .footer__inner {
      flex-direction: column;
      align-items: center;
      gap: 3rem;
    }

    .footer__contact,
    .footer__legal {
      max-width: 100%;
      width: 100%;
      text-align: center;
      padding-right: 0;
    }
  }
</style>
