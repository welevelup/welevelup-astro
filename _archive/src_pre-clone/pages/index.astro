---
import Layout from '../layouts/Layout.astro';

const campaigns = [
  { title: 'Abortion is Healthcare', image: 'https://welevelup.org/wp-content/uploads/2025/07/Copia-de-website-images.jpg', href: 'https://welevelup.org/petition/abortion-is-healthcare/', supporters: '6,1K' },
  { title: 'Stop sending pregnant women to prison', image: 'https://welevelup.org/wp-content/uploads/2025/07/1-720x540-1.jpg', href: 'https://levelup.yourmovement.org/p/pregnancy-in-prison', supporters: '13,1K' },
  { title: '#NoMoreLyes Take toxic hair relaxers off the shelves', image: 'https://welevelup.org/wp-content/uploads/2025/07/3-720x540-1.jpg', href: 'https://levelup.yourmovement.org/p/no-more-lyes', supporters: '6,4K' },
  { title: 'IPSO: Dignity for Dead Women', image: 'https://welevelup.org/wp-content/uploads/2025/07/19-720x540-1.jpg', href: 'https://welevelup.org/petition/dignity-for-dead-women/', supporters: '42K' },
  { title: 'Premier League and FA', image: 'https://welevelup.org/wp-content/uploads/2026/02/Captura-de-pantalla-2026-02-05-a-las-01.22.20.png', href: 'https://welevelup.org/petition/premier-league-and-fa/', supporters: '4,3K' },
  { title: 'Islington Council: Fund Holloway Women\'s Centre', image: 'https://welevelup.org/wp-content/uploads/2026/02/screenshot_2026-03-13_at_11.37.42_720.png', href: 'https://levelup.yourmovement.org/p/islington-council-finish-holloway-womens-centre', supporters: '' },
];

const blogPosts = [
  { title: 'It\'s Time to Reclaim the Socialist Roots of International Women\'s Day', author: 'Levelup', date: 'March 5, 2026', excerpt: 'International Working Women\'s Day began as a protest for labour rights and solidarity. As corporations and far-right movements reshape the narrative, reclaiming its radical roots and collective feminist struggle has never been more urgent.', image: 'https://welevelup.org/wp-content/uploads/2026/03/img_6011.jpg', href: '/blog/its-time-to-reclaim-the-socialist-roots-of-international-womens-day' },
  { title: 'Gender critical feminism isn\'t feminist', author: 'Vic Parsons', date: 'December 4, 2025', excerpt: 'Gender-critical activists present themselves as defenders of women\'s rights, yet their movement increasingly overlaps with far-right groups and targets trans people. Despite media amplification, they remain a loud minority whose actions harm both trans communities and essential feminist services.', image: 'https://welevelup.org/wp-content/uploads/2025/12/captura_de_pantalla_2025-12-02_a_la_s__16.04.17_720.png', href: '/blog/gender-critical-feminism-isnt-feminist' },
  { title: 'The griefs left unattended', author: 'Seyi Falodun-Liburd', date: 'November 19, 2025', excerpt: 'Grief doesn\'t only follow death — it appears in everyday losses and in the violence that shatters our sense of self. This piece explores why all forms of grief deserve recognition, community and language, and how acknowledging them can help us heal together.', image: 'https://welevelup.org/wp-content/uploads/2025/08/AFRO20HAIR2002052320GettyImages-1059157466-3-1024x576.jpg', href: '/blog/the-griefs-left-unattended' },
  { title: 'Beyond sympathy: Feminist solidarity without deservingness', author: 'Starling', date: 'August 19, 2025', excerpt: 'This piece challenges the "line of deservingness" that limits feminist demands and excludes women deemed unworthy of dignity or justice. Liberation means refusing respectability politics and confronting the systems that harm us all — because none of us are free until everyone is free.', image: '', href: '/blog/beyond-sympathy-feminist-solidarity-without-deservingness' },
  { title: 'Why expanding criminalisation is a feminist issue', author: 'Levelup', date: 'June 26, 2025', excerpt: 'The government\'s move to criminalise Palestine Action and expand police powers threatens protest rights, feminist organising and the safety of marginalised communities. While partial abortion reforms distract attention, authoritarian policies advance quietly. This blog explains what\'s happening — and how we can resist.', image: '', href: '/blog/why-expanding-criminalisation-is-a-feminist-issue' },
  { title: 'Abortion is healthcare: why decriminalisation must include health workers', author: 'Levelup', date: 'May 30, 2025', excerpt: 'Abortion is healthcare — yet in Britain it remains criminalised, enabling rising prosecution, surveillance and stigma. This piece explains how criminalisation harms patients and providers, how anti-abortion forces exploit the moment, and why full decriminalisation and cultural change are urgently needed.', image: '', href: '/blog/abortion-is-healthcare-why-decriminalisation-must-include-health-workers' },
  { title: 'Why we need to start moving offline', author: 'Ruvimbo Kuuzabuwe', date: 'February 28, 2025', excerpt: '', image: 'https://welevelup.org/wp-content/uploads/2025/02/IMG_9654-1024x683-1.jpg', href: '/blog/why-we-need-to-start-moving-offline' },
  { title: 'Why the Media Should Focus on Diddy\'s Violence, Not his Kinks', author: 'Ruvimbo Kuuzabuwe', date: '', excerpt: '', image: 'https://welevelup.org/wp-content/uploads/2025/08/1bcf84b0-760a-11ef-b02d-c5f3b724a1ea.jpg-2-e1727713609747.webp', href: '/blog/why-the-media-should-focus-on-diddys-violence-not-his-kinks' },
];
---

<Layout>
  {/* ===== HERO (c89219b) — full-width, bg image cover, flex column center ===== */}
  <section class="hero">
    <div class="hero__inner">
      <p class="hero__subtitle">We are a feminist community campaigning for gender justice in the UK.</p>
      <p class="hero__subtitle">Take action on our latest campaign:</p>
      <h2 class="hero__title">#NO MORE LYES</h2>
      <div class="hero__buttons">
        <a class="hero__btn hero__btn--primary" href="https://levelup.yourmovement.org/p/no-more-lyes" target="_blank" rel="noopener">Sign the petition</a>
        <a class="hero__btn hero__btn--secondary hero__hide-mobile" href="https://committees.parliament.uk/writtenevidence/160638/pdf/" target="_blank" rel="noopener">Explore Our Hair Relaxer Research Submission</a>
      </div>
      <p class="hero__subtitle">Big beauty brands like L'Oréal must remove toxic ingredients from hair relaxers.</p>
      <p class="hero__subtitle">The price of Black women's beauty should never be our health.</p>
    </div>
  </section>

  {/* ===== WHO WE ARE (ec6f030) — boxed, flex row, gap 20px, padding 2.5em ===== */}
  <section class="who-we-are">
    <div class="who-we-are__inner">
      <div class="who-we-are__label">
        <h2>WHO WE ARE</h2>
      </div>
      <div class="who-we-are__text">
        <p>We create digital tools and campaigns that interrupt cultural moments to fight for gender justice – <a href="/what-we-are-proud-of">like flying a plane banner over a football match to break the silence around rape in sports, pushing ITV to drop plastic surgery adverts from Love Island and producing the UK's first media guidelines on reporting domestic abuse deaths</a>.</p>
        <p>We're working towards a world where people of all genders are loved and liberated from bodily and systemic violence. We do this in our campaign coalitions, and through gathering with community like our <a href="/campaigns/we-protect-us">monthly workshops on bystander intervention and intervening in police violence.</a></p>
        <p>Our movement includes feminists from a range of backgrounds and all genders, centering the voices and liberation of people who experience gender injustice: women, gender-nonconforming and trans people.</p>
      </div>
    </div>
  </section>

  {/* ===== COLLECTIVE CARE (6555619) — boxed, flex column, padding 0 top 2.5em bottom ===== */}
  <section class="collective-care">
    <div class="collective-care__inner">
      <h2 class="collective-care__title">HOW COLLECTIVE CARE CAN CHANGE SOCIETY</h2>
      <div class="collective-care__row">
        <div class="collective-care__video">
          <div class="collective-care__video-wrap">
            <iframe src="https://www.youtube.com/embed/xj-alDQD2fg" title="Level Up TEDxLondon talk" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        <div class="collective-care__text">
          <p>Level Up's vision is a world where everyone is loved and liberated. We believe that collective care is the route to building this world. Level Up co-directors Seyi and Janey explained what this means in a TedxLondon talk in March 2023.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ===== NEXT EVENT (65e0e558) — boxed, padding 1.5em ===== */}
  <section class="next-event">
    <div class="next-event__inner">
      <div class="next-event__header">
        <h2 class="next-event__title">NEXT EVENT</h2>
      </div>
      <div class="next-event__grid">
        <p class="next-event__empty">There are no upcoming events right now. Subscribe to our mailing list to stay updated</p>
      </div>
    </div>
  </section>

  {/* ===== CAMPAIGNS (9f5db00) — full-width, bg navy, padding 1.8em top 2.5em bottom ===== */}
  <section class="campaigns">
    {/* Title row (921728b) — boxed */}
    <div class="campaigns__title-row">
      <h2 class="campaigns__heading campaigns__heading--desktop">SIGN OUR PETITIONS</h2>
      <h2 class="campaigns__heading campaigns__heading--mobile">CAMPAIGNS</h2>
    </div>
    {/* Grid (afdfffb) — 3 cols, gap 20px, items bg lime margin 5px */}
    <div class="campaigns__grid-wrap">
      <div class="campaigns__grid">
        {campaigns.map((c) => (
          <a href={c.href} target="_blank" rel="noopener" class="petition-card">
            <div class="petition-card__inner">
              <div class="petition-card__image">
                <img src={c.image} alt={c.title} loading="lazy" width="720" height="540" />
              </div>
            </div>
            <h2 class="petition-card__title">{c.title}</h2>
            {c.supporters && (
              <div class="petition-card__supporters">
                <svg viewBox="0 0 448 512" width="14" height="14" fill="currentColor"><path d="M224 256c70.7 0 128-57.3 128-128S294.7 0 224 0 96 57.3 96 128s57.3 128 128 128zm89.6 32h-16.7c-22.2 10.2-46.9 16-72.9 16s-50.6-5.8-72.9-16h-16.7C60.2 288 0 348.2 0 422.4V464c0 26.5 21.5 48 48 48h352c26.5 0 48-21.5 48-48v-41.6c0-74.2-60.2-134.4-134.4-134.4z"/></svg>
                <span>{c.supporters} supporters</span>
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
    {/* SEE MORE button */}
    <div class="campaigns__cta">
      <a href="/active-campaigns" class="campaigns__see-more">SEE MORE</a>
    </div>
  </section>

  {/* ===== FROM THE BLOG (0362161) — full-width, bg #A89BEC, padding 2.5em top 0 bottom ===== */}
  <section class="blog-section">
    <div class="blog-section__title-row">
      <h2 class="blog-section__title">FROM THE BLOG</h2>
    </div>
    <div class="blog-carousel" id="blogCarousel">
      <button class="blog-carousel__prev" aria-label="Previous">&lsaquo;</button>
      <button class="blog-carousel__next" aria-label="Next">&rsaquo;</button>
      <div class="blog-carousel__track" id="blogTrack">
        {blogPosts.map((post) => (
          <a href={post.href} class="blog-card">
            {post.image && (
              <div class="blog-card__img">
                <img src={post.image} alt={post.title} loading="lazy" />
              </div>
            )}
            <div class="blog-card__content">
              <p class="blog-card__title-text">{post.title}</p>
              <div class="blog-card__author">
                <svg viewBox="0 0 496 512" width="14" height="14" fill="currentColor"><path d="M248 104c-53 0-96 43-96 96s43 96 96 96 96-43 96-96-43-96-96-96zm0 144c-26.5 0-48-21.5-48-48s21.5-48 48-48 48 21.5 48 48-21.5 48-48 48zm0-240C111 8 0 119 0 256s111 248 248 248 248-111 248-248S385 8 248 8zm0 448c-49.7 0-95.1-18.3-130.1-48.4 14.9-23 40.4-38.6 69.6-39.5 20.8 6.4 40.6 9.6 60.5 9.6s39.7-3.1 60.5-9.6c29.2 1 54.7 16.5 69.6 39.5-35 30.1-80.4 48.4-130.1 48.4zm162.7-84.1c-24.4-31.4-62.1-51.9-105.1-51.9-10.2 0-26 9.6-57.6 9.6-31.5 0-47.4-9.6-57.6-9.6-42.9 0-80.6 20.5-105.1 51.9C61.9 339.2 48 299.2 48 256c0-110.3 89.7-200 200-200s200 89.7 200 200c0 43.2-13.9 83.2-37.3 115.9z"/></svg>
                <span>{post.author}</span>
              </div>
              {post.excerpt && <p class="blog-card__excerpt">{post.excerpt}</p>}
              {post.date && (
                <div class="blog-card__date">
                  <svg viewBox="0 0 448 512" width="12" height="12" fill="currentColor"><path d="M12 192h424c6.6 0 12 5.4 12 12v260c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V204c0-6.6 5.4-12 12-12zm436-44v-36c0-26.5-21.5-48-48-48h-48V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H160V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H48C21.5 64 0 85.5 0 112v36c0 6.6 5.4 12 12 12h424c6.6 0 12-5.4 12-12z"/></svg>
                  <time>{post.date}</time>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
      <div class="blog-carousel__dots" id="blogDots"></div>
    </div>
  </section>

  {/* ===== JOIN CTA (585520af) — full-width, bg #AB9DEA, padding 3em ===== */}
  <section class="join-cta">
    <div class="join-cta__inner">
      <h2 class="join-cta__title"><a href="https://levelup.yourmovement.org/p/join-us" target="_blank" rel="noopener">JOIN THE LEVEL UP COMMUNITY</a></h2>
    </div>
  </section>
</Layout>

<script>
  const track = document.getElementById('blogTrack') as HTMLElement | null;
  const dotsContainer = document.getElementById('blogDots') as HTMLElement | null;
  const prevBtn = document.querySelector('.blog-carousel__prev') as HTMLElement | null;
  const nextBtn = document.querySelector('.blog-carousel__next') as HTMLElement | null;
  if (track && dotsContainer && prevBtn && nextBtn) {
    const cards = Array.from(track.querySelectorAll('.blog-card')) as HTMLElement[];
    let currentIndex = 0;
    function getVisible() { return window.innerWidth <= 767 ? 1 : window.innerWidth <= 1024 ? 2 : 3; }
    function getCardW() { if (!cards.length) return 0; return cards[0].offsetWidth + (parseInt(getComputedStyle(track).gap) || 20); }
    function buildDots() { dotsContainer!.innerHTML = ''; const v = getVisible(); const t = Math.ceil(cards.length / v); for (let i = 0; i < t; i++) { const d = document.createElement('button'); d.className = 'blog-carousel__dot' + (i === 0 ? ' active' : ''); d.setAttribute('aria-label', `Slide ${i+1}`); d.addEventListener('click', () => goTo(i)); dotsContainer!.appendChild(d); } }
    function updateDots() { const v = getVisible(); const di = Math.floor(currentIndex / v); dotsContainer!.querySelectorAll('.blog-carousel__dot').forEach((d, i) => d.classList.toggle('active', i === di)); }
    function goTo(p: number) { const v = getVisible(); currentIndex = p * v; track!.style.transform = `translateX(-${currentIndex * getCardW()}px)`; updateDots(); }
    function prev() { const v = getVisible(); currentIndex = Math.max(0, currentIndex - v); track!.style.transform = `translateX(-${currentIndex * getCardW()}px)`; updateDots(); }
    function next() { const v = getVisible(); currentIndex = Math.min(Math.max(0, cards.length - v), currentIndex + v); track!.style.transform = `translateX(-${currentIndex * getCardW()}px)`; updateDots(); }
    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);
    buildDots();
    window.addEventListener('resize', () => { currentIndex = 0; track!.style.transform = 'translateX(0)'; buildDots(); });
  }
</script>

<style>
  /* ===== HERO (c89219b) =====
     bg image: cover center, flex column center, padding 6em top 4em bottom */
  .hero {
    background-image: url('/images/hero-nml.jpg');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 6em 0 4em;
  }
  .hero__inner {
    max-width: 1130px;
    width: 100%;
    padding: 0 20px;
  }
  /* 5d634f6 + c703ee4: DM Sans 24px/700, text-shadow, color #CBFF32 */
  .hero__subtitle {
    font-family: "DM Sans", sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #CBFF32;
    text-shadow: 0px 0px 10px rgba(0,0,0,0.3);
    line-height: 1.4;
    margin: 0;
  }
  /* 735cde0: DM Sans 5.7vw/800, color #CBFF32, padding 0 */
  .hero__title {
    font-family: "DM Sans", sans-serif;
    font-size: 5.7vw;
    font-weight: 800;
    color: #CBFF32;
    line-height: 1;
    margin: 0;
    padding: 0;
  }
  /* 5198fdb: flex row, gap 10px */
  .hero__buttons {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 10px;
    margin: 20px 0;
  }
  /* 6ce9a68: bg lime, Montserrat 20px/600, navy, radius 6px, pad 15px 30px */
  .hero__btn--primary {
    background-color: #CBFF32;
    color: #0D0A3E;
    font-family: "Montserrat", sans-serif;
    font-size: 20px;
    font-weight: 600;
    padding: 15px 30px;
    border-radius: 6px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .hero__btn--primary:hover { background-color: #CCFF33; }
  /* 5416038: transparent bg, white border 2px, radius 6px, pad 15px 30px */
  .hero__btn--secondary {
    background-color: transparent;
    color: #FFFFFF;
    font-family: "Montserrat", sans-serif;
    font-size: 20px;
    font-weight: 600;
    padding: 15px 30px;
    border: 2px solid #FFFFFF;
    border-radius: 6px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .hero__btn--secondary:hover { background-color: #FFFFFF; color: #0D0A3E; }

  /* ===== WHO WE ARE (ec6f030) =====
     boxed 1130px, flex row, gap 20px, padding 2.5em */
  .who-we-are {
    background-color: #EDEBD2;
    padding: 0;
  }
  .who-we-are__inner {
    max-width: 1130px;
    margin: 0 auto;
    padding: 2.5em 20px;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 20px;
  }
  /* 0ab1587: 30% width, justify flex-start */
  .who-we-are__label {
    width: 30%;
    display: flex;
    justify-content: flex-start;
    align-self: center;
  }
  /* 8edf19d: blogh 800, line-height 1em, section-sub-title */
  .who-we-are__label h2 {
    font-family: "blogh", "DM Sans", sans-serif;
    font-weight: 800;
    line-height: 1em;
    letter-spacing: -0.45px;
  }
  /* 892005d: flex 1, self flex-start */
  .who-we-are__text {
    flex: 1;
    align-self: flex-start;
    padding-top: 8px;
  }
  /* 8294cf1: DM Sans 18px/400/24px */
  .who-we-are__text p {
    font-family: "DM Sans", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    margin-bottom: 20px;
  }
  .who-we-are__text p:last-child { margin-bottom: 0; }
  /* links: #AB9DEA */
  .who-we-are__text a { color: #AB9DEA; }

  /* ===== COLLECTIVE CARE (6555619) =====
     boxed, flex column, pad 0 top 2.5em bottom */
  .collective-care {
    background-color: #EDEBD2;
    padding: 0;
  }
  .collective-care__inner {
    max-width: 1130px;
    margin: 0 auto;
    padding: 0em 20px 2.5em;
  }
  /* 6ace755: blogh 1.125em/700, #0C0A3E */
  .collective-care__title {
    font-family: "blogh", "DM Sans", sans-serif;
    font-size: 1.125em;
    font-weight: 700;
    color: #0C0A3E;
    line-height: 1em;
    margin-bottom: 20px;
  }
  /* 84c9f9e: flex row, gap 30px */
  .collective-care__row {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 30px;
  }
  /* 336c189: flex 1, padding 0 */
  .collective-care__video { flex: 1; min-width: 0; }
  .collective-care__video-wrap {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }
  .collective-care__video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  /* 7814de2: 60% width, padding 0 */
  .collective-care__text {
    width: 60%;
    padding-top: 8px;
  }
  .collective-care__text p {
    font-family: "DM Sans", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
  }

  /* ===== NEXT EVENT (65e0e558) =====
     boxed, padding 1.5em */
  .next-event {
    background-color: #EDEBD2;
    padding: 0;
  }
  .next-event__inner {
    max-width: 1130px;
    margin: 0 auto;
    padding: 1.5em 20px;
  }
  .next-event__header {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }
  /* 484edde0: blogh 3.2em/700, #0C0A3E */
  .next-event__title {
    font-family: "blogh", "DM Sans", sans-serif;
    font-size: 3.2em;
    font-weight: 700;
    color: #0C0A3E;
    line-height: 1em;
  }
  .next-event__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
  }
  .next-event__empty {
    grid-column: 1 / -1;
    font-family: "DM Sans", sans-serif;
    font-size: 18px;
    line-height: 24px;
    text-align: center;
    padding: 20px;
    background-color: #e8e8e8;
    border: 1px solid #c4c4c4;
  }

  /* ===== CAMPAIGNS (9f5db00) =====
     full-width, bg navy, padding 1.8em top 2.5em bottom */
  .campaigns {
    background-color: #0D0A3E;
    padding: 1.8em 0 2.5em;
  }
  .campaigns__title-row {
    max-width: 1130px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  /* d3eddea: blogh 800, lime, section-sub-title */
  .campaigns__heading {
    font-family: "blogh", "DM Sans", sans-serif;
    font-weight: 800;
    line-height: 1em;
    color: #CBFF32;
    text-align: center;
  }
  .campaigns__heading--mobile { display: none; }
  /* afdfffb: grid 3 cols, gap 20px */
  .campaigns__grid-wrap {
    max-width: 1130px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .campaigns__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  /* ue-grid-item: bg lime, margin 5px */
  .petition-card {
    background-color: #CBFF32;
    margin: 5px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
    transition: all 200ms ease-in-out;
  }
  /* 4dcce48f: padding 25px, bg lime */
  .petition-card__inner {
    padding: 0;
  }
  /* 57769a91: img width 100% */
  .petition-card__image img {
