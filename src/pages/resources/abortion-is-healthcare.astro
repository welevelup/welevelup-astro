---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { extract } from '../../lib/extractHtml';
import homeRaw from '../../_clone/index.html?raw';
const { headInner, bodyClass } = extract(homeRaw);
---

<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Abortion Is Healthcare Resources",
    "description": "A curated collection of research, media guidelines, reporting, and advocacy resources on abortion access, decriminalisation, and reproductive justice in the UK, compiled by Level Up's Abortion Is Healthcare campaign.",
    "url": "https://welevelup.org/resources/abortion-is-healthcare",
    "publisher": { "@type": "Organization", "name": "Level Up", "url": "https://welevelup.org" },
    "about": { "@type": "Thing", "name": "Abortion access, decriminalisation, and reproductive healthcare in the UK" }
  })}</script>

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is abortion legal in England, Scotland and Wales?",
        "acceptedAnswer": { "@type": "Answer", "text": "Abortion is legal in England, Scotland and Wales up to 24 weeks under the 1967 Abortion Act, and beyond 24 weeks in limited circumstances. However, abortion remains in the criminal law: it is still technically a crime under the 1861 Offences Against the Person Act, meaning people can be — and have been — prosecuted for ending their own pregnancies. Decriminalisation campaigns argue that abortion should be treated as healthcare, not a criminal matter." }
      },
      {
        "@type": "Question",
        "name": "What is the Abortion Is Healthcare campaign?",
        "acceptedAnswer": { "@type": "Answer", "text": "Abortion Is Healthcare is a campaign by feminist organisation Level Up calling for full decriminalisation of abortion in the UK and for media, policymakers, and the public to treat abortion as the healthcare matter it is. The campaign produced media guidelines with medical experts and abortion providers to help journalists report on abortion with accuracy, compassion, and sensitivity — and to stop framing it as a debate." }
      },
      {
        "@type": "Question",
        "name": "Why are people being prosecuted for abortion in the UK?",
        "acceptedAnswer": { "@type": "Answer", "text": "Despite abortion being widely available through the NHS and licensed providers, the 1861 Offences Against the Person Act still criminalises self-managed abortion outside the legal framework. Prosecutions have increased in recent years, affecting people who ended pregnancies at home — often during the Covid-19 pandemic when home use of abortion pills was temporarily permitted. Campaigners and medical bodies argue these prosecutions are unjust and harmful." }
      },
      {
        "@type": "Question",
        "name": "How does media coverage affect abortion access?",
        "acceptedAnswer": { "@type": "Answer", "text": "Media coverage of abortion shapes public opinion, influences policy, and can either reduce or reinforce stigma around an essential healthcare procedure. Research shows that inaccurate, sensationalised, or debate-framed coverage increases shame for people who have abortions and emboldens restrictive policy proposals. Level Up's Abortion Media Guidelines were created with journalists, medical experts, and abortion providers to promote accurate, compassionate reporting." }
      },
      {
        "@type": "Question",
        "name": "What do the Level Up Abortion Media Guidelines recommend?",
        "acceptedAnswer": { "@type": "Answer", "text": "The Level Up Abortion Media Guidelines, developed with Jade Hammond and Ikamara Larasi in partnership with medical experts and abortion providers, recommend that journalists treat abortion as a public health issue rather than a moral debate, use person-centred language, avoid false balance with anti-abortion voices, include medical expert perspectives, and be aware of the legal risks faced by people who share their abortion stories publicly." }
      },
      {
        "@type": "Question",
        "name": "What is decriminalisation of abortion and why does it matter?",
        "acceptedAnswer": { "@type": "Answer", "text": "Decriminalisation means removing abortion from criminal law entirely so that ending a pregnancy is treated as a healthcare decision rather than a potential crime. In the UK context, it would mean repealing the relevant sections of the 1861 Offences Against the Person Act. Decriminalisation does not mean removing any gestational limits or medical safeguards — it simply means that people cannot be jailed for decisions about their own pregnancies. The Royal College of Obstetricians and Gynaecologists and other medical bodies support decriminalisation." }
      }
    ]
  })}</script>

  <section class="nr-hero" aria-labelledby="nr-hero-heading">
    <div class="nr-hero-inner">
      <div class="nr-hero-text">
        <span class="nr-eyebrow">Abortion Is Healthcare</span>
        <h1 id="nr-hero-heading" class="nr-hero-title">Research &amp;<br/>Resources</h1>
        <p class="nr-hero-subtitle">Evidence, guidance, and media resources on abortion access and healthcare.</p>
      </div>
      <div class="nr-hero-image" aria-hidden="true">
        <img src="https://welevelup.org/wp-content/uploads/2025/08/Screenshot-2024-06-04-at-22-1.webp" alt="Abortion Is Healthcare campaign — media guidelines and resources by Level Up" loading="eager" />
      </div>
    </div>
  </section>

  <section class="nr-intro" aria-label="About this resource collection">
    <div class="nr-intro-inner">
      <p>Prosecutions and investigations for ending a pregnancy are rising. News outlets play an important role in this, because media discourse shapes public opinion on abortion.</p>
      <p>Journalists have the power to reduce shame and stigma, and build a society that shows compassion for people who need abortions. But some media outlets perpetuate harmful myths and stereotypes, and incite debate on an essential healthcare procedure.</p>
      <p>Inspired by the work of Abortion Dream Team in Poland, Level Up worked with medical experts, abortion providers and journalists to create media guidelines for reporting on abortion in Britain. The guidelines share tips on how to report with accuracy, compassion, and sensitivity. Most importantly, they encourage journalists to treat abortion as a public health issue, not a debate.</p>
      <a href="https://welevelup.org/petition/abortion-is-healthcare/" target="_blank" rel="noopener" class="nr-intro-btn">Sign the petition →</a>
    </div>
  </section>

  <section class="nr-faq" aria-labelledby="nr-faq-heading">
    <div class="nr-faq-inner">
      <h2 id="nr-faq-heading" class="nr-faq-title">Common Questions</h2>
      <div class="nr-faq-list">
        <details class="nr-faq-item">
          <summary class="nr-faq-q">Is abortion legal in England, Scotland and Wales?</summary>
          <div class="nr-faq-a">Abortion is legal up to 24 weeks under the 1967 Abortion Act, but it remains in criminal law under the 1861 Offences Against the Person Act. People have been prosecuted for ending their own pregnancies. Decriminalisation campaigns argue abortion should be treated as healthcare, not a criminal matter.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">What is the Abortion Is Healthcare campaign?</summary>
          <div class="nr-faq-a">Abortion Is Healthcare is Level Up's campaign calling for full decriminalisation of abortion in the UK and for media, policymakers, and the public to treat abortion as healthcare. The campaign produced media guidelines with medical experts and abortion providers to support accurate, compassionate journalism.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">Why are people being prosecuted for abortion in the UK?</summary>
          <div class="nr-faq-a">The 1861 Offences Against the Person Act still criminalises self-managed abortion outside the legal framework. Prosecutions have increased, affecting people who ended pregnancies at home — often during the Covid-19 pandemic. Campaigners and medical bodies argue these prosecutions are unjust and harmful.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">How does media coverage affect abortion access?</summary>
          <div class="nr-faq-a">Inaccurate or debate-framed media coverage increases stigma, affects people's decisions, and emboldens restrictive policy proposals. Level Up's Abortion Media Guidelines help journalists report with accuracy and compassion, treating abortion as the public health issue it is.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">What do the Level Up Abortion Media Guidelines recommend?</summary>
          <div class="nr-faq-a">The guidelines recommend treating abortion as a public health issue rather than a moral debate, using person-centred language, avoiding false balance with anti-abortion voices, including medical expert perspectives, and being aware of legal risks faced by people who share their abortion stories publicly.</div>
        </details>
        <details class="nr-faq-item">
          <summary class="nr-faq-q">What is decriminalisation and why does it matter?</summary>
          <div class="nr-faq-a">Decriminalisation removes abortion from criminal law so it is treated as a healthcare decision rather than a potential crime. It does not remove gestational limits or medical safeguards — it means people cannot be jailed for decisions about their own pregnancies. The Royal College of Obstetricians and Gynaecologists supports decriminalisation.</div>
        </details>
      </div>
    </div>
  </section>

