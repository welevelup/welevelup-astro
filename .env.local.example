# ─────────────────────────────────────────────────────────────────────────────
# META ADS — Pixel tracking
# ─────────────────────────────────────────────────────────────────────────────
# Get this from Meta Events Manager → your Pixel → Settings → Pixel ID
# Must start with PUBLIC_ so Astro exposes it to the browser
PUBLIC_META_PIXEL_ID=replace_with_your_pixel_id

# ─────────────────────────────────────────────────────────────────────────────
# MOLLIE — NEW organization (Astro flow, future donations)
# ─────────────────────────────────────────────────────────────────────────────
# Get this from the NEW Mollie org (the one you create separately from the
# GiveWP/WordPress org). Dashboard → Developers → API keys.
# Use the test_xxx key for local development, live_xxx only when going live.
MOLLIE_API_KEY=test_replace_me

# Public-facing URL of this site, used to build redirect URLs after Mollie
# checkout. In dev: your ngrok URL (https://abc123.ngrok-free.app). In prod:
# https://welevelup.org
PUBLIC_SITE_URL=https://welevelup.org

# Webhook URL Mollie will POST to when a payment status changes.
# In dev with ngrok: https://abc123.ngrok-free.app/api/mollie-webhook
# In prod:           https://welevelup.org/api/mollie-webhook
MOLLIE_WEBHOOK_URL=https://welevelup.org/api/mollie-webhook

# ─────────────────────────────────────────────────────────────────────────────
# MOLLIE — LEGACY organization (existing GiveWP / WordPress donations)
# ─────────────────────────────────────────────────────────────────────────────
# ONLY needed for the one-shot script that updates webhookUrl on the 70
# existing recurring subscriptions. Once you've run scripts/update-legacy-
# webhooks.ts successfully, you can DELETE this from .env.local.
MOLLIE_LEGACY_API_KEY=live_replace_me

# Where the legacy GiveWP webhook handler still lives. Currently the Cloudways
# bare URL of the WordPress install — used as the destination when we update
# the existing 70 subscriptions before DNS cutover. Replace with your real
# Cloudways URL (or a subdomain like https://legacy.welevelup.org).
MOLLIE_LEGACY_WEBHOOK_URL=https://wordpress-1535009-6048693.cloudwaysapps.com/?give-listener=mollie
