      <div class="ol-sign-right">
        <form class="ol-form" action="https://formspree.io/f/REPLACE_WITH_FORM_ID" method="POST">
          <input type="hidden" name="_subject" value="New open letter signature — #NoMoreLyes" />
          <input type="hidden" name="_next" value="https://welevelup.org/nomorelyes-open-letter-to-loreal/?signed=1" />
          <div class="ol-form-row">
            <div class="ol-form-field">
              <label class="ol-form-label" for="ol-first-name">First name</label>
              <input id="ol-first-name" class="ol-form-input" type="text" name="first_name" placeholder="Your first name" required />
            </div>
            <div class="ol-form-field">
              <label class="ol-form-label" for="ol-last-name">Last name</label>
              <input id="ol-last-name" class="ol-form-input" type="text" name="last_name" placeholder="Your last name" required />
            </div>
          </div>
          <div class="ol-form-field">
            <label class="ol-form-label" for="ol-email">Email address</label>
            <input id="ol-email" class="ol-form-input" type="email" name="email" placeholder="hello@example.com" required />
          </div>
          <div class="ol-form-field">
            <label class="ol-form-label" for="ol-postcode">Postcode</label>
            <input id="ol-postcode" class="ol-form-input" type="text" name="postcode" placeholder="e.g. E1 6RF" />
          </div>
          <div class="ol-form-check">
            <input type="checkbox" id="ol-updates" name="keep_me_updated" class="ol-check-input" />
            <label for="ol-updates" class="ol-check-label">Keep me updated on this campaign and Level Up news</label>
          </div>
          <button type="submit" class="ol-form-submit">
            Sign the open letter <span aria-hidden="true">→</span>
          </button>
          <p class="ol-form-note">Your details are stored securely. We will never share your personal data with third parties.</p>
        </form>
      </div>
    </div>
