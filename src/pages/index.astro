---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { extract } from '../lib/extractHtml';
import rawHtml from '../_clone/index.html?raw';

const { headInner, bodyClass, mainContent } = extract(rawHtml);
---
<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />

  <!-- Animated announcement bar -->
  <div class="ic-bar">
    <div class="ic-bar-track">
      <a href="/active-campaigns/islington-council-finish-holloway-womens-centre" class="ic-bar-item">
        <span class="ic-bar-badge">NEW</span>
        <span>Islington Council must finish Holloway Women's Centre — Sign the petition →</span>
      </a>
      <a href="/active-campaigns/islington-council-finish-holloway-womens-centre" class="ic-bar-item">
        <span class="ic-bar-badge">NEW</span>
        <span>Islington Council must finish Holloway Women's Centre — Sign the petition →</span>
      </a>
      <a href="/active-campaigns/islington-council-finish-holloway-womens-centre" class="ic-bar-item">
        <span class="ic-bar-badge">NEW</span>
        <span>Islington Council must finish Holloway Women's Centre — Sign the petition →</span>
      </a>
    </div>
  </div>

  <Fragment set:html={mainContent} />

  <!-- WHO WE ARE — Proposal A: Split layout -->
  <section class="home-who">
    <div class="home-who-inner">
      <div class="home-who-left">
        <h2>WHO<br/>WE<br/>ARE</h2>
      </div>
      <div class="home-who-right">
        <p>We create digital tools and campaigns that interrupt cultural moments to fight for gender justice – <a href="/what-we-are-proud-of">like flying a plane banner over a football match to break the silence around rape in sports, pushing ITV to drop plastic surgery adverts from Love Island and producing the UK's first media guidelines on reporting domestic abuse deaths</a>.</p>
        <p>We're working towards a world where people of all genders are loved and liberated from bodily and systemic violence. We do this in our campaign coalitions, and through gathering with community like our <a href="/active-campaigns/we-protect-us">monthly workshops on bystander intervention and intervening in police violence.</a></p>
        <p>Our movement includes feminists from a range of backgrounds and all genders, centering the voices and liberation of people who experience gender injustice: women, gender-nonconforming and trans people.</p>
      </div>
    </div>
  </section>

  <!-- HOW COLLECTIVE CARE — Proposal B: Cinematic -->
  <section class="home-video">
    <div class="home-video-header">
      <span class="home-video-tag">TedxLondon · March 2023</span>
      <h2>How Collective Care<br/>Can Change Society</h2>
      <p>Level Up's vision is a world where everyone is loved and liberated. We believe that collective care is the route to building this world.</p>
    </div>
    <div class="home-video-player">
      <iframe src="https://www.youtube.com/embed/xj-alDQD2fg?controls=1" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen loading="lazy"></iframe>
    </div>
  </section>

  <!-- ISLINGTON COUNCIL BANNER -->
  <section class="ic-banner">
    <div class="ic-banner-content">
      <span class="ic-banner-label">Featured Campaign</span>
      <h2>Finish Holloway Women's Centre</h2>
      <p>The centre is built but standing empty. Tell Islington Council: keep your promise to deliver vital support for women facing trauma, violence, poverty and homelessness.</p>
      <div class="ic-banner-actions">
        <a href="https://levelup.yourmovement.org/p/islington-council-finish-holloway-womens-centre" class="ic-banner-btn-primary" target="_blank" rel="noopener">Sign the petition</a>
        <a href="/active-campaigns/islington-council-finish-holloway-womens-centre" class="ic-banner-btn">Learn more →</a>
      </div>
    </div>
  </section>

  <!-- PETITIONS SECTION -->
  <section class="home-petitions">
    <div class="home-petitions-inner">
      <h2 class="home-petitions-title">Sign Our Petitions</h2>
      <div class="home-petitions-grid">
        <a href="/active-campaigns/abortion-is-healthcare" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/10/Screenshot-2024-06-14-at-12-1.webp" alt="Abortion is Healthcare" loading="lazy" />
          <div class="home-petition-body">
            <h3>Abortion is Healthcare</h3>
            <span class="home-petition-supporters">6.1K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/pregnancy-in-prison" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/10/FREEBABIES3-1-scaled-1.webp" alt="Pregnancy in Prison" loading="lazy" />
          <div class="home-petition-body">
            <h3>Stop sending pregnant women to prison</h3>
            <span class="home-petition-supporters">13.1K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/nomorelyes-2" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/08/NML11-2.webp" alt="#NoMoreLyes" loading="lazy" />
          <div class="home-petition-body">
            <h3>#NoMoreLyes: Take toxic hair relaxers off the shelves</h3>
            <span class="home-petition-supporters">6.4K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/media-guidelines-domestic-abuse" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/08/image-5.webp" alt="Dignity for Dead Women" loading="lazy" />
          <div class="home-petition-body">
            <h3>IPSO: Dignity for Dead Women</h3>
            <span class="home-petition-supporters">29.2K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/sexual-violence-in-football" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2025/08/image-4.webp" alt="Sexual Violence in Football" loading="lazy" />
          <div class="home-petition-body">
            <h3>Premier League and FA</h3>
            <span class="home-petition-supporters">4.3K supporters</span>
          </div>
        </a>
        <a href="/active-campaigns/islington-council-finish-holloway-womens-centre" class="home-petition-card">
          <img src="https://welevelup.org/wp-content/uploads/2026/02/screenshot_2026-03-13_at_11.37.42_720.png" alt="Islington Council" loading="lazy" />
          <div class="home-petition-body">
            <h3>Islington Council: Fund Holloway Women's Centre</h3>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- BLOG SECTION -->
  <section class="home-blog">
    <div class="home-blog-inner">
      <span class="home-blog-label">From the Blog</span>
      <h2 class="home-blog-title">Feminist Thinking</h2>
      <div class="home-blog-grid">
        <a href="/blog/its-time-to-reclaim-the-socialist-roots-of-international-womens-day" class="home-blog-card home-blog-card--featured">
          <span class="home-blog-tag">Solidarity &amp; Movement</span>
          <h3>It's Time to Reclaim the Socialist Roots of International Women's Day</h3>
          <span class="home-blog-read">Read article →</span>
        </a>
        <a href="/blog/abortion-is-healthcare-why-decriminalisation-must-include-health-workers" class="home-blog-card">
          <span class="home-blog-tag">Reproductive Rights</span>
          <h3>Abortion Is Healthcare: Why Decriminalisation Must Include Health Workers</h3>
          <span class="home-blog-read">Read →</span>
        </a>
        <a href="/blog/ending-prison-for-pregnant-women-a-non-reformist-reform" class="home-blog-card">
          <span class="home-blog-tag">Criminalisation &amp; Justice</span>
          <h3>Ending Prison for Pregnant Women: A Non-Reformist Reform</h3>
          <span class="home-blog-read">Read →</span>
        </a>
        <a href="/blog/gender-critical-feminism-isnt-feminist" class="home-blog-card">
          <span class="home-blog-tag">Trans-Inclusive Feminism</span>
          <h3>"Gender-Critical" Feminism Isn't Feminist — It's Anti-Trans Politics</h3>
          <span class="home-blog-read">Read →</span>
        </a>
        <a href="/blog/why-the-media-should-focus-on-diddys-violence-not-his-kinks" class="home-blog-card">
          <span class="home-blog-tag">Media &amp; Violence</span>
          <h3>Why the Media Should Focus on Diddy's Violence, Not His Kinks</h3>
          <span class="home-blog-read">Read →</span>
        </a>
        <a href="/blog/why-we-need-to-start-moving-offline" class="home-blog-card">
          <span class="home-blog-tag">Solidarity &amp; Movement</span>
          <h3>Why We Need to Start Moving Offline</h3>
          <span class="home-blog-read">Read →</span>
        </a>
      </div>
      <a href="/blog" class="home-blog-all">View all posts →</a>
    </div>
  </section>

  <section class="home-cta">
    <h2>Join the Level Up community</h2>
    <p>Campaign updates, event invitations, and feminist thinking — straight to your inbox.</p>
    <a href="https://levelup.yourmovement.org/p/join-us" class="home-cta-btn" target="_blank" rel="noopener">Join us</a>
  </section>
  <Footer />
</Layout>

<style is:global>
  .home-cta {
    background: #0C0A3E;
    padding: 80px 24px 40px;
    text-align: center;
    font-family: 'DM Sans', sans-serif;
  }
  .home-cta h2 {
    font: 800 40px/0.9 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.04em;
    margin: 0 0 16px;
  }
  .home-cta p {
    font: 400 17px/1.5 'DM Sans', sans-serif;
    color: rgba(238, 235, 211, 0.6);
    max-width: 440px;
    margin: 0 auto 32px;
  }
  .home-cta-btn {
    display: inline-block;
    background: #CCFF33;
    color: #0C0A3E;
    font: 700 14px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 18px 40px;
    text-decoration: none;
  }
  .home-cta-btn:hover { background: #fff; }

  /* Hide clone's Who We Are + Collective Care sections */
  [data-id="ec6f030"],
  [data-id="6555619"] {
    display: none !important;
  }

  /* ── WHO WE ARE — Split layout ───────────────────────── */
  .home-who { background: #EEEBD3; padding: 80px 24px; font-family: 'DM Sans', sans-serif; }
  .home-who-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 2fr; gap: 64px; align-items: start; }
  .home-who-left h2 { font: 800 clamp(56px, 10vw, 96px)/0.85 'DM Sans'; color: #0C0A3E; letter-spacing: -0.05em; margin: 0; }
  .home-who-right p { font: 400 18px/1.7 'DM Sans'; color: rgba(12,10,62,0.8); margin: 0 0 20px; }
  .home-who-right a { color: #A89CED; text-decoration: none; }
  .home-who-right a:hover { color: #0C0A3E; text-decoration: underline; }

  /* ── VIDEO — Cinematic full-width ────────────────────── */
  .home-video { background: #0C0A3E; padding: 80px 24px 64px; font-family: 'DM Sans', sans-serif; }
  .home-video-header { max-width: 800px; margin: 0 auto; text-align: center; padding-bottom: 48px; }
  .home-video-tag { font: 600 11px/1 'DM Sans'; text-transform: uppercase; letter-spacing: 0.12em; color: #A89CED; display: block; margin-bottom: 20px; }
  .home-video-header h2 { font: 800 clamp(36px, 7vw, 56px)/0.92 'DM Sans'; color: #CCFF33; letter-spacing: -0.04em; margin: 0 0 20px; }
  .home-video-header p { font: 400 18px/1.5 'DM Sans'; color: rgba(238,235,211,0.6); max-width: 550px; margin: 0 auto; }
  .home-video-player { max-width: 900px; margin: 0 auto; }
  .home-video-player iframe { width: 100%; aspect-ratio: 16/9; border: none; display: block; }

  @media (max-width: 768px) {
    .home-who-inner { grid-template-columns: 1fr; gap: 24px; }
    .home-who-left h2 { font-size: 56px; }
  }

  /* ═══ Animated announcement bar (marquee) ═══ */
  .ic-bar {
    background: #A89CED;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
  }
  .ic-bar-track {
    display: inline-flex;
    animation: marquee 20s linear infinite;
  }
  .ic-bar-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 48px;
    font: 600 13px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    text-decoration: none;
    white-space: nowrap;
  }
  .ic-bar:hover { background: #CCFF33; }
  .ic-bar:hover .ic-bar-item { color: #0C0A3E; }
  .ic-bar:hover .ic-bar-track { animation-play-state: paused; }
  .ic-bar-badge {
    background: #0C0A3E;
    color: #CCFF33;
    font: 700 10px/1 'DM Sans';
    padding: 4px 8px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.33%); }
  }

  /* ═══ PROPOSAL B: Featured banner ═══ */
  .ic-banner {
    background: #A89CED;
    padding: 64px 24px;
    font-family: 'DM Sans', sans-serif;
    text-align: center;
  }
  .ic-banner-content {
    max-width: 700px;
    margin: 0 auto;
  }
  .ic-banner-label {
    font: 600 11px/1 'DM Sans';
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #0C0A3E;
    opacity: 0.6;
    display: block;
    margin-bottom: 16px;
  }
  .ic-banner-content h2 {
    font: 800 36px/0.95 'DM Sans';
    color: #CCFF33;
    letter-spacing: -0.03em;
    margin: 0 0 16px;
  }
  .ic-banner-content p {
    font: 400 17px/1.5 'DM Sans';
    color: rgba(12,10,62,0.7);
    margin: 0;
    max-width: 550px;
    margin: 0 auto;
  }
  .ic-banner-actions {
    margin-top: 24px;
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }
  .ic-banner-btn-primary {
    display: inline-block;
    background: #CCFF33;
    color: #0C0A3E;
    font: 900 14px/1 'DM Sans';
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 16px 32px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .ic-banner-btn-primary:hover { background: #fff; color: #0C0A3E; }
  .ic-banner-btn {
    font: 700 13px/1 'DM Sans';
    color: #0C0A3E !important;
    text-decoration: none !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .ic-banner-btn:hover { color: #CCFF33 !important; }

  /* ═══ PROPOSAL C: Full hero ═══ */
  .ic-hero-full {
    background: #A89CED;
    padding: 64px 24px;
    text-align: center;
    font-family: 'DM Sans', sans-serif;
  }
  .ic-hero-full-inner { max-width: 700px; margin: 0 auto; }
  .ic-hero-full-label {
    font: 600 11px/1 'DM Sans';
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #0C0A3E;
    display: block;
    margin-bottom: 16px;
  }
  .ic-hero-full-title {
    font: 800 clamp(32px, 7vw, 48px)/0.95 'DM Sans';
    color: #0C0A3E;
    letter-spacing: -0.03em;
    margin: 0 0 16px;
  }
  .ic-hero-full p {
    font: 400 17px/1.5 'DM Sans';
    color: rgba(12,10,62,0.7);
    margin: 0 0 24px;
  }
  .ic-hero-full-btn {
    display: inline-block;
    background: #0C0A3E;
    color: #CCFF33;
    font: 700 14px/1 'DM Sans';
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 16px 36px;
    text-decoration: none;
  }
  .ic-hero-full-btn:hover { background: #CCFF33; color: #0C0A3E; }

  @media (max-width: 768px) {
    .ic-banner { grid-template-columns: 1fr; }
    .ic-banner-img { height: 200px; }
  }

  /* ── Petitions section ───────────────────────────────── */
  .home-petitions {
    background: #0C0A3E;
    padding: 80px 24px;
    font-family: 'DM Sans', sans-serif;
  }
  .home-petitions-inner { max-width: 1100px; margin: 0 auto; }
  .home-petitions-title {
    font: 800 48px/0.9 'DM Sans', sans-serif !important;
    color: #CCFF33 !important;
    letter-spacing: -0.04em !important;
    margin: 0 0 40px !important;
    text-align: center;
  }
  .home-petitions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .home-petition-card {
    background: rgba(238,235,211,0.06);
    text-decoration: none;
    overflow: hidden;
    transition: all 0.25s;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(238,235,211,0.08);
    position: relative;
  }
  .home-petition-card:hover {
    transform: translateY(-4px);
    border-color: #CCFF33;
  }
  .home-petition-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .home-petition-body {
    padding: 20px 20px 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .home-petition-body h3 {
    font: 700 17px/1.2 'DM Sans', sans-serif;
    color: #EEEBD3;
    margin: 0 0 12px;
    flex: 1;
  }
  .home-petition-supporters {
    font: 600 11px/1 'DM Sans', sans-serif;
    color: #CCFF33;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .home-petition-supporters::before {
    content: '✦';
    font-size: 8px;
  }
  @media (max-width: 768px) {
    .home-petitions-grid { grid-template-columns: 1fr; }
    .home-petitions-title { font-size: 36px; }
  }

  /* Hide empty "Next Event" section */
  [data-id="65e0e558"],
  [data-id="684b07bb"],
  [data-id="484edde0"] {
    display: none !important;
  }
  /* Hide duplicate "Join the Level Up Community" purple CTA section */
  [data-id="585520af"] {
    display: none !important;
  }
  /* Hide clone's broken blog section */
  [data-id="0362161"] {
    display: none !important;
  }
  /* Hide clone's broken petitions section */
  [data-id="9f5db00"] {
    display: none !important;
  }

  /* ── Blog section ────────────────────────────────────── */
  .home-blog {
    background: #A89CED;
    padding: 80px 24px;
    font-family: 'DM Sans', sans-serif;
  }
  .home-blog-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .home-blog-label {
    font: 600 12px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(238,235,211,0.5);
    display: block;
    margin-bottom: 12px;
  }
  .home-blog-title {
    font: 800 48px/0.9 'DM Sans', sans-serif;
    color: #FFFFFF;
    letter-spacing: -0.04em;
    margin: 0 0 40px;
  }
  .home-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .home-blog-card {
    background: rgba(12, 10, 62, 0.25);
    padding: 32px 28px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(12, 10, 62, 0.1);
    transition: all 0.2s;
    min-height: 180px;
  }
  .home-blog-card:hover {
    background: rgba(12, 10, 62, 0.4);
    border-color: #CCFF33;
  }
  .home-blog-card--featured {
    grid-column: 1 / -1;
    background: rgba(12, 10, 62, 0.35);
    border-color: rgba(204,255,51,0.15);
    min-height: auto;
    padding: 40px 32px;
  }
  .home-blog-card--featured h3 {
    font-size: 28px !important;
  }
  .home-blog-tag {
    font: 600 10px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(238,235,211,0.5);
  }
  .home-blog-card h3 {
    font: 700 18px/1.2 'DM Sans', sans-serif;
    color: #CCFF33;
    margin: 0;
    flex: 1;
  }
  .home-blog-read {
    font: 600 13px/1 'DM Sans', sans-serif;
    color: #CCFF33;
    margin-top: auto;
  }
  .home-blog-all {
    display: inline-block;
    margin-top: 32px;
    font: 700 14px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #EEEBD3;
    text-decoration: none;
  }
  .home-blog-all:hover { color: #CCFF33; }

  @media (max-width: 768px) {
    .home-blog-grid { grid-template-columns: 1fr; }
    .home-blog-card--featured { grid-column: 1; }
    .home-blog-title { font-size: 36px; }
    .ic-bar { font-size: 11px; padding: 10px 16px; }
    .ic-banner { grid-template-columns: 1fr; }
    .ic-banner-img { height: 200px; }
    .ic-banner-content { padding: 32px 24px; }
    .ic-banner-content h2 { font-size: 24px; }
    .home-petitions-title { font-size: 32px !important; }
    .home-petitions-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
    .home-petition-card img { height: 140px; }
    .home-petition-body h3 { font-size: 14px; }
  }
  @media (max-width: 480px) {
    .home-petitions-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Force lazy-loaded images (WP Smush uses data-src)
  document.querySelectorAll('img[data-src]').forEach((img) => {
    const dataSrc = img.getAttribute('data-src');
    if (dataSrc) img.setAttribute('src', dataSrc);
  });

  // Force lazy iframes (videos, embeds)
  document.querySelectorAll('iframe[data-src]').forEach((iframe) => {
    const dataSrc = iframe.getAttribute('data-src');
    if (dataSrc) iframe.setAttribute('src', dataSrc);
  });

  // Force background images from data-bg
  document.querySelectorAll('[data-bg]').forEach((el) => {
    const bg = el.getAttribute('data-bg');
    if (bg) (el as HTMLElement).style.backgroundImage = `url(${bg})`;
  });

  // Load srcset images
  document.querySelectorAll('img[data-srcset]').forEach((img) => {
    const srcset = img.getAttribute('data-srcset');
    if (srcset) img.setAttribute('srcset', srcset);
  });

  // Load Elementor video widgets (youtube embeds stored in data-settings)
  document.querySelectorAll('.elementor-widget-video').forEach((widget) => {
    const settings = widget.querySelector('[data-settings]')?.getAttribute('data-settings');
    if (!settings) return;
    try {
      const parsed = JSON.parse(settings);
      const url = parsed.youtube_url;
      if (!url) return;
      const videoId = url.match(/(?:youtu\.be\/|v=)([^&?/]+)/)?.[1];
      if (!videoId) return;
      const container = widget.querySelector('.elementor-video') || widget.querySelector('.elementor-wrapper') || widget;
      if (!container.querySelector('iframe')) {
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube.com/embed/${videoId}?controls=1`;
        iframe.style.cssText = 'width:100%;aspect-ratio:16/9;border:none;';
        iframe.allow = 'accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture';
        iframe.allowFullscreen = true;
        container.appendChild(iframe);
      }
    } catch {}
  });

  // Hide "NEXT EVENT" section and empty events message
  document.querySelectorAll('.elementor-heading-title').forEach((el) => {
    if (el.textContent?.trim() === 'NEXT EVENT') {
      // Hide the parent section
      let parent = el.closest('.e-con.e-parent') || el.closest('.elementor-section');
      if (parent) (parent as HTMLElement).style.display = 'none';
    }
  });
  // Also hide the events empty message
  document.querySelectorAll('.ue-no-posts-found').forEach((el) => {
    let parent = el.closest('.e-con.e-parent') || el.closest('.elementor-section');
    if (parent) (parent as HTMLElement).style.display = 'none';
  });

  // Hide duplicate "JOIN THE LEVEL UP COMMUNITY" from clone
  let joinCount = 0;
  document.querySelectorAll('.elementor-heading-title').forEach((el) => {
    if (el.textContent?.trim() === 'JOIN THE LEVEL UP COMMUNITY') {
      joinCount++;
      if (joinCount === 1) {
        let parent = el.closest('.e-con.e-parent') || el.closest('.elementor-section');
        if (parent) (parent as HTMLElement).style.display = 'none';
      }
    }
  });
</script>
