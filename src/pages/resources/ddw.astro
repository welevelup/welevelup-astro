  }
  @media (max-width: 640px) {
    .nr-hero { padding: 72px 20px 56px; }
    .nr-featured { padding: 28px 24px; }
    .nr-resource-item { grid-template-columns: 32px 1fr; }
    .nr-item-end { flex-direction: row; align-items: center; grid-column: 2; margin-top: 8px; }
  }
</style>

<script>
  (() => {
    const items = Array.from(document.querySelectorAll<HTMLElement>('.nr-resource-item'));
    const catSel = document.getElementById('nr-cat') as HTMLSelectElement;
    const typeSel = document.getElementById('nr-type') as HTMLSelectElement;
    const platformSel = document.getElementById('nr-platform') as HTMLSelectElement;
    const topicSel = document.getElementById('nr-topic') as HTMLSelectElement;
    const resetBtn = document.getElementById('nr-reset') as HTMLButtonElement;
    const selects = [catSel, typeSel, platformSel, topicSel];

    function getFilters() {
      return {
        cat: catSel?.value || 'all',
        type: typeSel?.value || 'all',
        platform: platformSel?.value || 'all',
        topic: topicSel?.value || 'all',
      };
    }

    function itemMatches(item: HTMLElement, f: ReturnType<typeof getFilters>) {
      const tags = (item.dataset.tags || '').split(' ');
      const itemType = item.dataset.type || '';
      const source = item.dataset.source || '';
      const topics = (item.dataset.topic || '').split(' ');
      return (f.cat === 'all' || tags.includes(f.cat))
        && (f.type === 'all' || itemType === f.type)
        && (f.platform === 'all' || source === f.platform)
        && (f.topic === 'all' || topics.includes(f.topic));
    }

    function updateCounts() {
      const f = getFilters();
      selects.forEach(sel => {
        if (!sel) return;
        const key = sel.id.replace('nr-', '') as keyof typeof f;
        Array.from(sel.options).forEach(opt => {
          if (opt.value === 'all') { opt.disabled = false; return; }
          const testF = { ...f, [key]: opt.value };
          const count = items.filter(item => itemMatches(item, testF)).length;
          const label = opt.dataset.label || opt.text.replace(/ \(\d+\)$/, '');
          opt.dataset.label = label;
          opt.text = count > 0 ? `${label} (${count})` : label;
          opt.disabled = count === 0;
        });
      });
    }

    function syncUrl(f: ReturnType<typeof getFilters>) {
      const params = new URLSearchParams();
      if (f.cat !== 'all') params.set('cat', f.cat);
      if (f.type !== 'all') params.set('type', f.type);
      if (f.platform !== 'all') params.set('platform', f.platform);
      if (f.topic !== 'all') params.set('topic', f.topic);
      const qs = params.toString();
      history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
    }

    function applyFilters() {
      const f = getFilters();
      items.forEach(item => {
        item.style.display = itemMatches(item, f) ? '' : 'none';
      });
      updateCounts();
      syncUrl(f);
      const anyActive = Object.values(f).some(v => v !== 'all');
      if (resetBtn) resetBtn.style.display = anyActive ? '' : 'none';
    }

    function loadFromUrl() {
      const params = new URLSearchParams(location.search);
      if (catSel && params.has('cat')) catSel.value = params.get('cat')!;
      if (typeSel && params.has('type')) typeSel.value = params.get('type')!;
      if (platformSel && params.has('platform')) platformSel.value = params.get('platform')!;
      if (topicSel && params.has('topic')) topicSel.value = params.get('topic')!;
    }

    selects.forEach(sel => sel?.addEventListener('change', applyFilters));

    resetBtn?.addEventListener('click', () => {
      selects.forEach(sel => { if (sel) sel.value = 'all'; });
      applyFilters();
    });

    loadFromUrl();
    applyFilters();
  })();
</script>
