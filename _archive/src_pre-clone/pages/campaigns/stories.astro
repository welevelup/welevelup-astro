---
import CampaignLayout from '../../layouts/CampaignLayout.astro';
---

<CampaignLayout
  title="Space for Memory | Level Up"
  description="A space for the Level Up community to share stories and memories. Join the community."
  heroImage="https://welevelup.org/wp-content/uploads/2025/08/Screenshot-2024-06-14-at-12-1.webp"
  heroTitle="Space for memory"
>

  <h1 class="campaign-main-title">Space for memory</h1>

  <div class="campaign-block campaign-block--navy">
    <p class="campaign-block__heading">Join the Level Up Community</p>
    <div class="campaign-block__text">
      <p>Be part of a movement working for gender justice. Join the Level Up community to stay connected, share your stories, and take action.</p>
      <p style="margin-top: 1.5rem;">
        <a href="https://levelup.yourmovement.org/p/join-us" target="_blank" rel="noopener" class="campaign-btn">Click and Join the Level Up Community</a>
      </p>
    </div>
  </div>

</CampaignLayout>
