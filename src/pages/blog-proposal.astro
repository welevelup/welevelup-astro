---
/**
 * Blog listing — 2 design proposals on one page.
 * Uses real blog post titles from the content collection.
 */
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { extract } from '../lib/extractHtml';
import homeRaw from '../_clone/index.html?raw';
const { headInner, bodyClass } = extract(homeRaw);

const posts = [
  { slug: 'abortion-is-healthcare-why-decriminalisation-must-include-health-workers', title: 'Abortion Is Healthcare: Why Decriminalisation Must Include Health Workers', tag: 'Reproductive Rights', date: '12 Sep 2025' },
  { slug: 'ending-prison-for-pregnant-women-a-non-reformist-reform', title: 'Ending Prison for Pregnant Women: A Non-Reformist Reform', tag: 'Criminalisation & Justice', date: '28 Aug 2025' },
  { slug: 'gender-critical-feminism-isnt-feminist', title: '"Gender-Critical" Feminism Isn\'t Feminist — It\'s Anti-Trans Politics', tag: 'Trans-Inclusive Feminism', date: '15 Jul 2025' },
  { slug: 'why-the-media-should-focus-on-diddys-violence-not-his-kinks', title: 'Why the Media Should Focus on Diddy\'s Violence, Not His Kinks', tag: 'Media & Violence', date: '3 Jun 2025' },
  { slug: 'why-we-need-to-start-moving-offline', title: 'Why We Need to Start Moving Offline', tag: 'Solidarity & Movement', date: '20 May 2025' },
  { slug: 'how-we-choose-our-campaigns', title: 'How We Choose Our Campaigns', tag: 'Solidarity & Movement', date: '8 Apr 2025' },
  { slug: 'beyond-sympathy-feminist-solidarity-without-deservingness', title: 'Beyond Sympathy: Feminist Solidarity Without Deservingness', tag: 'Solidarity & Movement', date: '22 Mar 2025' },
  { slug: 'the-griefs-left-unattended', title: 'The Griefs Left Unattended', tag: 'Solidarity & Movement', date: '10 Feb 2025' },
  { slug: 'why-expanding-criminalisation-is-a-feminist-issue', title: 'Why Expanding Criminalisation Is a Feminist Issue', tag: 'Criminalisation & Justice', date: '5 Jan 2025' },
  { slug: 'its-time-to-reclaim-the-socialist-roots-of-international-womens-day', title: "It's Time to Reclaim the Socialist Roots of International Women's Day", tag: 'Solidarity & Movement', date: '8 Mar 2024' },
];
---
<Layout headHtml={headInner} bodyClass={bodyClass}>
  <Nav />

  <!-- ═══════════════════════════════════════════════════════
       PROPOSAL A — Magazine editorial
       Featured post large on left, rest stacked on right
       ═══════════════════════════════════════════════════════ -->
  <div class="bp-label-bar">Proposal A — Magazine Editorial</div>

  <section class="bp-a-hero">
    <div class="bp-a-inner">
      <span class="bp-a-label">From the Blog</span>
      <h1 class="bp-a-title">Feminist Thinking</h1>
      <p class="bp-a-subtitle">Analysis, perspectives, and feminist thinking from Level Up on campaigns, policy, and gender justice in the UK.</p>
    </div>
  </section>

  <section class="bp-a-content">
    <div class="bp-a-grid">
      <!-- Featured -->
      <a href={`/blog/${posts[0].slug}`} class="bp-a-featured">
        <div class="bp-a-featured-img" style="background-image:url('https://welevelup.org/wp-content/uploads/2025/08/image-5.webp')"></div>
        <div class="bp-a-featured-body">
          <span class="bp-a-tag">{posts[0].tag}</span>
          <h2>{posts[0].title}</h2>
          <span class="bp-a-date">{posts[0].date}</span>
          <span class="bp-a-read">Read article →</span>
        </div>
      </a>

      <!-- Side stack -->
      <div class="bp-a-stack">
        {posts.slice(1, 5).map(post => (
          <a href={`/blog/${post.slug}`} class="bp-a-card">
            <span class="bp-a-tag">{post.tag}</span>
            <h3>{post.title}</h3>
            <span class="bp-a-date">{post.date}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Rest in 3-col grid -->
    <div class="bp-a-rest">
      {posts.slice(5).map(post => (
        <a href={`/blog/${post.slug}`} class="bp-a-rest-card">
          <span class="bp-a-tag">{post.tag}</span>
          <h3>{post.title}</h3>
          <div class="bp-a-rest-meta">
            <span class="bp-a-date">{post.date}</span>
            <span class="bp-a-read">Read →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="bp-spacer"></div>

  <!-- ═══════════════════════════════════════════════════════
       PROPOSAL B — Clean list / newspaper
       Full-width rows with dividers
       ═══════════════════════════════════════════════════════ -->
  <div class="bp-label-bar">Proposal B — Clean List / Newspaper</div>

  <section class="bp-b-hero">
    <div class="bp-b-inner">
      <h1 class="bp-b-title">Blog</h1>
      <p class="bp-b-subtitle">Feminist analysis and thinking from Level Up.</p>
      <div class="bp-b-filters">
        <button class="bp-b-filter bp-b-filter--active">All</button>
        <button class="bp-b-filter">Reproductive Rights</button>
        <button class="bp-b-filter">Criminalisation</button>
        <button class="bp-b-filter">Media & Violence</button>
        <button class="bp-b-filter">Solidarity</button>
        <button class="bp-b-filter">Trans-Inclusive</button>
      </div>
    </div>
  </section>

  <section class="bp-b-list">
    <div class="bp-b-list-inner">
      {posts.map((post, i) => (
        <a href={`/blog/${post.slug}`} class={`bp-b-row ${i === 0 ? 'bp-b-row--featured' : ''}`}>
          <div class="bp-b-row-left">
            <span class="bp-b-tag">{post.tag}</span>
            <h3>{post.title}</h3>
          </div>
          <div class="bp-b-row-right">
            <span class="bp-b-date">{post.date}</span>
            <span class="bp-b-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  .bp-label-bar {
    background: #A89CED;
    color: #0C0A3E;
    font: 900 14px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
    padding: 12px;
  }
  .bp-spacer { height: 80px; background: #EEEBD3; }

  /* ═══ PROPOSAL A ═══════════════════════════════════════ */
  .bp-a-hero {
    background: #0C0A3E;
    padding: 80px 24px 60px;
  }
  .bp-a-inner { max-width: 1100px; margin: 0 auto; }
  .bp-a-label {
    font: 600 12px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #A89CED;
    display: block;
    margin-bottom: 12px;
  }
  .bp-a-title {
    font: 800 64px/0.9 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.04em;
    margin: 0 0 16px;
  }
  .bp-a-subtitle {
    font: 400 18px/1.5 'DM Sans', sans-serif;
    color: rgba(238,235,211,0.6);
    max-width: 500px;
  }

  .bp-a-content {
    background: #EEEBD3;
    padding: 40px 24px 64px;
  }
  .bp-a-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2px;
  }
  .bp-a-featured {
    text-decoration: none;
    color: #0C0A3E;
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .bp-a-featured:hover { box-shadow: 0 4px 24px rgba(12,10,62,0.1); }
  .bp-a-featured-img {
    height: 280px;
    background-size: cover;
    background-position: center;
  }
  .bp-a-featured-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .bp-a-featured-body h2 {
    font: 800 28px/1.05 'DM Sans', sans-serif;
    color: #0C0A3E;
    letter-spacing: -0.03em;
    margin: 0;
  }
  .bp-a-tag {
    font: 600 10px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #A89CED;
  }
  .bp-a-date {
    font: 400 13px/1 'DM Sans', sans-serif;
    color: rgba(12,10,62,0.4);
  }
  .bp-a-read {
    font: 600 13px/1 'DM Sans', sans-serif;
    color: #0C0A3E;
    margin-top: auto;
  }

  .bp-a-stack {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .bp-a-card {
    background: #fff;
    padding: 24px 28px;
    text-decoration: none;
    color: #0C0A3E;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    border-left: 3px solid transparent;
    transition: all 0.2s;
  }
  .bp-a-card:hover { border-left-color: #CCFF33; }
  .bp-a-card h3 {
    font: 700 16px/1.2 'DM Sans', sans-serif;
    color: #0C0A3E;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .bp-a-rest {
    max-width: 1100px;
    margin: 40px auto 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .bp-a-rest-card {
    background: #fff;
    padding: 28px 24px;
    text-decoration: none;
    color: #0C0A3E;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 3px solid transparent;
    transition: all 0.2s;
  }
  .bp-a-rest-card:hover { border-top-color: #CCFF33; }
  .bp-a-rest-card h3 {
    font: 700 17px/1.2 'DM Sans', sans-serif;
    color: #0C0A3E;
    margin: 0;
    flex: 1;
  }
  .bp-a-rest-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  /* ═══ PROPOSAL B ═══════════════════════════════════════ */
  .bp-b-hero {
    background: #0C0A3E;
    padding: 80px 24px 48px;
  }
  .bp-b-inner { max-width: 900px; margin: 0 auto; }
  .bp-b-title {
    font: 800 72px/0.9 'DM Sans', sans-serif;
    color: #CCFF33;
    letter-spacing: -0.04em;
    margin: 0 0 12px;
  }
  .bp-b-subtitle {
    font: 400 18px/1.5 'DM Sans', sans-serif;
    color: rgba(238,235,211,0.6);
    margin: 0 0 32px;
  }
  .bp-b-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .bp-b-filter {
    font: 600 11px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 10px 18px;
    background: transparent;
    color: rgba(238,235,211,0.5);
    border: 1px solid rgba(238,235,211,0.15);
    cursor: pointer;
    transition: all 0.15s;
  }
  .bp-b-filter:hover { color: #CCFF33; border-color: #CCFF33; }
  .bp-b-filter--active {
    background: #CCFF33;
    color: #0C0A3E;
    border-color: #CCFF33;
  }

  .bp-b-list {
    background: #EEEBD3;
    padding: 0 24px 64px;
  }
  .bp-b-list-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .bp-b-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(12,10,62,0.08);
    text-decoration: none;
    color: #0C0A3E;
    transition: all 0.15s;
  }
  .bp-b-row:hover {
    padding-left: 16px;
    border-bottom-color: #CCFF33;
  }
  .bp-b-row--featured {
    padding: 40px 0;
  }
  .bp-b-row--featured h3 {
    font-size: 28px !important;
  }
  .bp-b-row-left {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .bp-b-tag {
    font: 600 10px/1 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #A89CED;
  }
  .bp-b-row h3 {
    font: 700 18px/1.2 'DM Sans', sans-serif;
    color: #0C0A3E;
    margin: 0;
    letter-spacing: -0.02em;
  }
  .bp-b-row-right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .bp-b-date {
    font: 400 13px/1 'DM Sans', sans-serif;
    color: rgba(12,10,62,0.4);
    white-space: nowrap;
  }
  .bp-b-arrow {
    font-size: 20px;
    color: #CCFF33;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .bp-b-row:hover .bp-b-arrow { opacity: 1; }

  @media (max-width: 768px) {
    .bp-a-grid { grid-template-columns: 1fr; }
    .bp-a-rest { grid-template-columns: 1fr; }
    .bp-a-title { font-size: 40px; }
    .bp-b-title { font-size: 48px; }
    .bp-b-row { flex-direction: column; align-items: flex-start; gap: 8px; }
    .bp-b-row-right { gap: 8px; }
  }
</style>
