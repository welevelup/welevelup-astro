  <script>
    (function() {
      const filters = document.querySelectorAll('.pc-filter');
      const cards = document.querySelectorAll('.pc-card');
      const noResults = document.getElementById('no-results');

      function applyFilter(topic) {
        let visible = 0;
        cards.forEach(card => {
          const match = topic === 'all' || card.dataset.topic === topic;
          card.hidden = !match;
          if (match) visible++;
        });
        noResults.hidden = visible > 0;
        filters.forEach(btn => {
          const isActive = btn.dataset.filter === topic;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      }

      filters.forEach(btn => {
        btn.addEventListener('click', () => applyFilter(btn.dataset.filter));
      });

      const urlFilter = new URLSearchParams(location.search).get('filter');
      if (urlFilter) applyFilter(urlFilter);
    })();
  </script>
