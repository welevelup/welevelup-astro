    .dp-timeline::before {
      content: '';
      position: absolute;
      left: 19px; top: 8px; bottom: 8px;
      width: 2px;
      background: linear-gradient(to bottom, rgba(12,10,62,0.1) 0%, #A89CED 25%, #CCFF33 65%, #4CAF50 100%);
    }
    .dp-tl-node {
      position: relative;
      display: grid;
      grid-template-columns: 64px 1fr;
      gap: 0 16px;
      margin-bottom: 64px;
    }
    .dp-tl-node:last-child { margin-bottom: 0; }
    .dp-tl-dot {
      position: absolute;
      left: -56px; top: 4px;
      width: 40px; height: 40px;
      border-radius: 50%;
      background: #0C0A3E;
      border: 4px solid #EEEBD3;
      z-index: 1;
    }
    .dp-tl-dot--purple { background: #A89CED; }
    .dp-tl-dot--yellow { background: #CCFF33; }
    .dp-tl-dot--green { background: #4CAF50; }
    .dp-tl-year {
      font: 800 28px/1 'DM Sans', sans-serif;
      color: #0C0A3E !important;
      letter-spacing: -0.03em;
      padding-top: 6px;
      grid-column: 1;
      grid-row: 1 / span 2;
    }
    .dp-tl-body { grid-column: 2; }
    .dp-tl-body h3 {
      font: 700 20px/1.1 'DM Sans', sans-serif !important;
      color: #0C0A3E !important;
      margin: 24px 0 8px;
    }
    .dp-tl-body h3:first-child { margin-top: 0; }
    .dp-tl-body p {
      font: 400 16px/1.6 'DM Sans', sans-serif !important;
      color: rgba(12,10,62,0.75) !important;
      margin: 0 0 14px;
    }
    .dp-tl-body strong { color: #0C0A3E !important; }
    .dp-tl-body a { color: #0C0A3E !important; text-decoration: underline !important; text-decoration-color: #A89CED !important; }
    .dp-tl-body a:hover { color: #A89CED !important; }
    .dp-tl-node--highlight .dp-tl-body {
      background: rgba(204,255,51,0.12);
      padding: 20px;
      margin: -8px -20px;
      border-left: 3px solid #CCFF33;
    }

    .dp-actions {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-top: 32px;
    }
    .dp-action {
      background: #EEEBD3;
      padding: 32px 24px;
      text-decoration: none !important;
      color: #0C0A3E;
      border: 2px solid transparent;
      transition: border-color 0.2s;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .dp-action:hover { border-color: #CCFF33; }
    .dp-action strong { font: 700 20px/1.1 'DM Sans', sans-serif !important; color: #0C0A3E !important; }
    .dp-action p { text-decoration: none !important; font-size: 15px !important; color: rgba(12,10,62,0.6) !important; margin: 0 !important; }
    .dp-arrow { font-size: 20px; color: #CCFF33; margin-top: auto; padding-top: 8px; }

    .dp-final-cta { background: #A89CED; padding: 64px 24px; text-align: center; }
    .dp-final-cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 32px; }
    .dp-btn-large { padding: 22px 48px !important; font-size: 16px !important; }
    .dp-btn-secondary-light {
      display: inline-block;
      background: #0C0A3E;
      color: #FFFFFF !important;
      font: 700 14px/1 'DM Sans', sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 18px 36px;
      text-decoration: none !important;
      border: 2px solid #0C0A3E;
      transition: all 0.2s;
    }
    .dp-btn-secondary-light:hover { color: #CCFF33 !important; }

    .dp-cta { background: #0C0A3E; padding: 80px 24px; text-align: center; }
    .dp-cta h2 { margin: 0 0 16px; font: 800 40px/0.9 'DM Sans', sans-serif !important; color: #CCFF33 !important; letter-spacing: -0.04em !important; }
    .dp-cta p { color: rgba(238,235,211,0.6) !important; font: 400 17px/1.5 'DM Sans', sans-serif !important; max-width: 440px; margin: 0 auto 32px !important; }

    @media (max-width: 768px) {
      .dp-hero { min-height: 100vh; flex-direction: column; justify-content: center; padding: 80px 24px 60px; }
      .dp-stats-inner { grid-template-columns: repeat(2, 1fr); }
      .dp-stat { border-bottom: 1px solid rgba(12,10,62,0.1); }
      .dp-tl-node { grid-template-columns: 1fr; }
      .dp-tl-year { grid-column: 1; grid-row: 1; margin-bottom: 8px; }
      .dp-tl-body { grid-column: 1; }
      .dp-timeline { padding-left: 48px; }
      .dp-tl-dot { left: -48px; width: 36px; height: 36px; }
      .dp-final-cta-buttons { flex-direction: column; align-items: center; }
    }
  </style>
</Layout>
